<mxfile host="app.diagrams.net">
  <diagram id="m03-org-scp-inherit" name="Organizations OU SCP inheritance">
    <mxGraphModel dx="1000" dy="520" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1180" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- AWS Organizations title icon -->
        <mxCell id="orgicon" value="AWS Organizations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CD2264;strokeColor=none;fontColor=#FFFFFF;fontSize=12;fontStyle=1;verticalLabelPosition=right;verticalAlign=middle;align=left;labelPosition=right;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="30" y="20" width="34" height="34" as="geometry" />
        </mxCell>

        <!-- Organization root management account icon (top right of root) -->
        <mxCell id="rooticon" value="Organization root&lt;br&gt;management account" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CD2264;strokeColor=none;fontColor=#232F3E;fontSize=12;fontStyle=0;verticalLabelPosition=right;verticalAlign=middle;align=left;labelPosition=right;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="600" y="20" width="34" height="34" as="geometry" />
        </mxCell>

        <!-- Organization-level boundary (dashed red) -->
        <mxCell id="orgbound" value="Organization-level boundary" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#DD344C;dashed=1;dashPattern=6 4;verticalAlign=top;align=left;fontColor=#232F3E;fontSize=12;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="30" y="60" width="540" height="610" as="geometry" />
        </mxCell>

        <!-- SCP note -->
