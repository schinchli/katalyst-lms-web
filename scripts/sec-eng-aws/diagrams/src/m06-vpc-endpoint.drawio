<mxfile host="app.diagrams.net">
  <diagram id="m06-vpc-endpoint" name="VPC endpoint">
    <mxGraphModel dx="1000" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1040" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="VPC endpoint overview" style="text;html=1;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="30" y="16" width="500" height="36" as="geometry" />
        </mxCell>

        <!-- Without / With headers + connecting arrow -->
