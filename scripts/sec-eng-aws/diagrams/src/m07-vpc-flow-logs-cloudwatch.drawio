            <mxPoint x="160" y="384" as="sourcePoint" />
            <mxPoint x="160" y="346" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- big arrow VPC -> CloudWatch Logs -->
        <mxCell id="bigArr" value="Amazon&lt;br&gt;CloudWatch Logs" style="endArrow=block;html=1;strokeColor=#8C4FFF;strokeWidth=3;fontColor=#16191F;fontSize=13;labelBackgroundColor=#FFFFFF;verticalAlign=bottom;" edge="1" parent="1" source="vpc" target="cwBox">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="0" y="-10" as="offset" />
