        </mxCell>

        <!-- CloudWatch Logs container -->
        <mxCell id="cwBox" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#16191F;strokeWidth=2;" vertex="1" parent="1">
