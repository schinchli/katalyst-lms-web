        <!-- annotation bottom -->
        <mxCell id="annBot" value="VPC Flow logs activated on &lt;b&gt;one elastic network&lt;br&gt;interface&lt;/b&gt;" style="text;html=1;align=left;fontColor=#16191F;fontSize=14;" vertex="1" parent="1">
