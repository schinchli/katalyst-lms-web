<mxfile host="app.diagrams.net">
  <diagram id="m07-vpcfl" name="Publishing VPC Flow logs to CloudWatch">
    <mxGraphModel dx="1100" dy="640" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1040" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Publishing VPC Flow logs to CloudWatch" style="text;html=1;align=left;verticalAlign=middle;fontColor=#16191F;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="18" width="760" height="40" as="geometry" />
        </mxCell>

        <!-- annotation top -->
        <mxCell id="annTop" value="VPC Flow logs activated on &lt;b&gt;one subnet&lt;/b&gt;" style="text;html=1;align=left;fontColor=#16191F;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="320" height="22" as="geometry" />
        </mxCell>

        <!-- arrow from top annotation into VPC -->
        <mxCell id="annTopArr" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="200" y="116" as="sourcePoint" />
            <mxPoint x="200" y="148" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- VPC container (green) -->
        <mxCell id="vpc" value="VPC" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1B8C3A;strokeWidth=2;dashed=1;verticalAlign=top;align=left;fontColor=#1B8C3A;fontSize=13;fontStyle=1;spacingLeft=28;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="60" y="150" width="300" height="220" as="geometry" />
        </mxCell>
        <mxCell id="vpcIcon" value="" style="sketch=0;fillColor=#8C4FFF;strokeColor=none;html=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.vpc;" vertex="1" parent="1">
          <mxGeometry x="66" y="154" width="22" height="22" as="geometry" />
        </mxCell>

        <!-- ENI1 -->
        <mxCell id="eni1" value="ENI1" style="sketch=0;fontColor=#16191F;fillColor=#8C4FFF;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elastic_network_interface;" vertex="1" parent="1">
          <mxGeometry x="86" y="196" width="48" height="48" as="geometry" />
        </mxCell>
        <!-- ENI2 -->
        <mxCell id="eni2" value="ENI2" style="sketch=0;fontColor=#16191F;fillColor=#8C4FFF;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elastic_network_interface;" vertex="1" parent="1">
          <mxGeometry x="226" y="196" width="48" height="48" as="geometry" />
        </mxCell>
        <!-- ENI3 -->
        <mxCell id="eni3" value="ENI3" style="sketch=0;fontColor=#16191F;fillColor=#8C4FFF;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elastic_network_interface;" vertex="1" parent="1">
          <mxGeometry x="86" y="296" width="48" height="48" as="geometry" />
        </mxCell>
        <!-- ENI4 -->
        <mxCell id="eni4" value="ENI4" style="sketch=0;fontColor=#16191F;fillColor=#8C4FFF;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elastic_network_interface;" vertex="1" parent="1">
          <mxGeometry x="226" y="296" width="48" height="48" as="geometry" />
        </mxCell>

        <!-- dashed connectors ENI1-ENI2 and ENI3-ENI4 (orange in original) -->
        <mxCell id="lnk12" value="" style="endArrow=none;html=1;strokeColor=#ED7100;strokeWidth=2;dashed=1;" edge="1" parent="1" source="eni1" target="eni2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lnk34" value="" style="endArrow=none;html=1;strokeColor=#ED7100;strokeWidth=2;dashed=1;" edge="1" parent="1" source="eni3" target="eni4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- VPC Flow logs label (to right of VPC) -->
        <mxCell id="vflLbl" value="VPC&lt;br&gt;Flow logs" style="text;html=1;align=center;fontColor=#16191F;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="300" y="250" width="80" height="40" as="geometry" />
