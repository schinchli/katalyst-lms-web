<mxfile host="app.diagrams.net">
  <diagram id="m03-fed-saml-oidc" name="Federation SAML OIDC trust">
    <mxGraphModel dx="1000" dy="520" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1180" pageHeight="520" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Corporate data center box -->
        <mxCell id="dc" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#232F3E;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="30" width="470" height="450" as="geometry" />
        </mxCell>
        <!-- corp building icon + title -->
        <mxCell id="dcicon" value="" style="shape=mxgraph.aws4.corporate_data_center;sketch=0;outlineConnect=0;fillColor=#5A6B86;strokeColor=none;html=1;" vertex="1" parent="1">
          <mxGeometry x="46" y="44" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="dctitle" value="Corporate data center" style="text;html=1;align=left;verticalAlign=middle;fontColor=#5A6B86;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="84" y="44" width="280" height="30" as="geometry" />
        </mxCell>

        <!-- Identity provider label -->
        <mxCell id="idplbl" value="Identity provider" style="text;html=1;align=left;verticalAlign=middle;fontColor=#232F3E;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="46" y="150" width="180" height="30" as="geometry" />
        </mxCell>
        <!-- IdP root node -->
        <mxCell id="idproot" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="230" y="155" width="44" height="24" as="geometry" />
        </mxCell>
        <!-- IdP three leaf nodes -->
        <mxCell id="idp1" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="350" y="120" width="44" height="24" as="geometry" />
        </mxCell>
        <mxCell id="idp2" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="350" y="155" width="44" height="24" as="geometry" />
        </mxCell>
        <mxCell id="idp3" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="350" y="190" width="44" height="24" as="geometry" />
        </mxCell>
        <!-- magenta connectors IdP tree -->
        <mxCell id="ce1" style="endArrow=none;html=1;strokeColor=#C2389A;strokeWidth=2;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="idproot" target="idp1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="312" y="167"/><mxPoint x="312" y="132"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="ce2" style="endArrow=none;html=1;strokeColor=#C2389A;strokeWidth=2;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="idproot" target="idp2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ce3" style="endArrow=none;html=1;strokeColor=#C2389A;strokeWidth=2;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="idproot" target="idp3">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="312" y="167"/><mxPoint x="312" y="202"/></Array></mxGeometry>
        </mxCell>

        <!-- Identity store label -->
        <mxCell id="storelbl" value="Identity&lt;br&gt;store" style="text;html=1;align=left;verticalAlign=middle;fontColor=#232F3E;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="46" y="320" width="120" height="40" as="geometry" />
        </mxCell>
        <!-- dashed purple boundary around identity store -->
        <mxCell id="storebound" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B1E66;strokeWidth=3;dashed=1;dashPattern=8 6;" vertex="1" parent="1">
          <mxGeometry x="180" y="300" width="280" height="120" as="geometry" />
        </mxCell>
        <!-- database cylinder (identity store) -->
        <mxCell id="dbicon" value="" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#FFFFFF;strokeColor=#232F3E;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="220" y="320" width="70" height="80" as="geometry" />
        </mxCell>
        <!-- magenta rings on cylinder -->
        <mxCell id="ring1" value="" style="endArrow=none;html=1;strokeColor=#C2389A;strokeWidth=2.5;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="222" y="352" as="sourcePoint"/><mxPoint x="288" y="352" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="ring2" value="" style="endArrow=none;html=1;strokeColor=#C2389A;strokeWidth=2.5;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="222" y="372" as="sourcePoint"/><mxPoint x="288" y="372" as="targetPoint"/></mxGeometry>
        </mxCell>
        <!-- users next to db -->
        <mxCell id="storeusers" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#9B6FE0;strokeColor=none;html=1;aspect=fixed;shape=mxgraph.aws4.users;" vertex="1" parent="1">
          <mxGeometry x="330" y="335" width="56" height="52" as="geometry" />
        </mxCell>

        <!-- AWS dark box -->
        <mxCell id="awsbox" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="900" y="30" width="250" height="250" as="geometry" />
        </mxCell>
        <mxCell id="awslogo" value="aws" style="text;html=1;align=center;verticalAlign=middle;fontColor=#FFFFFF;fontSize=64;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="930" y="80" width="190" height="120" as="geometry" />
        </mxCell>

        <!-- SAML / OIDC text -->
        <mxCell id="samltxt" value="SAML 2.0 or OpenID&lt;br&gt;Connect (OIDC)" style="text;html=1;align=center;verticalAlign=middle;fontColor=#232F3E;fontSize=20;" vertex="1" parent="1">
          <mxGeometry x="540" y="70" width="320" height="60" as="geometry" />
        </mxCell>

        <!-- bidirectional Trust arrow -->
        <mxCell id="trust" value="" style="shape=flexArrow;startArrow=block;endArrow=block;html=1;fillColor=#3B1E66;strokeColor=#3B1E66;fontColor=#FFFFFF;fontSize=22;fontStyle=1;width=18;startWidth=42;endWidth=42;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="520" y="170" as="sourcePoint"/><mxPoint x="880" y="170" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Access path: identity store -> up to AWS box bottom -->
        <mxCell id="access" value="Access through AWS Management&lt;br&gt;Console, AWS CLI, or API" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=4;rounded=0;fontColor=#232F3E;fontSize=18;verticalAlign=top;labelBackgroundColor=none;exitX=1;exitY=0.5;entryX=0.5;entryY=1;" edge="1" parent="1" source="storebound" target="awsbox">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1025" y="360" />
            </Array>
            <mxPoint x="0" y="80" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="trustlbl" value="Trust" style="text;html=1;align=center;verticalAlign=middle;fontColor=#FFFFFF;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="158" width="120" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
