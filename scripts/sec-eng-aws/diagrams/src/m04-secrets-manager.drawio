<mxfile host="app.diagrams.net">
  <diagram id="m04-sm" name="Using Secrets Manager">
    <mxGraphModel dx="1000" dy="700" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1060" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Using Secrets Manager" style="text;html=1;align=left;verticalAlign=middle;fontSize=24;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="30" y="20" width="700" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rule" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#8C4FFF;strokeColor=none;gradientColor=#E7157B;gradientDirection=east;" vertex="1" parent="1">
          <mxGeometry x="30" y="64" width="1000" height="4" as="geometry" />
        </mxCell>

        <!-- Left: clients -->
        <mxCell id="mobile" value="Mobile&#10;apps" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=14;aspect=fixed;shape=mxgraph.aws4.mobile_client;" vertex="1" parent="1">
          <mxGeometry x="70" y="150" width="58" height="58" as="geometry" />
        </mxCell>
        <mxCell id="website" value="Websites" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=14;aspect=fixed;shape=mxgraph.aws4.client;" vertex="1" parent="1">
          <mxGeometry x="70" y="280" width="58" height="58" as="geometry" />
        </mxCell>
        <mxCell id="services" value="Services" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#8C4FFF;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=14;aspect=fixed;shape=mxgraph.aws4.resource;resIcon=mxgraph.aws4.generic_application;" vertex="1" parent="1">
          <mxGeometry x="70" y="410" width="58" height="58" as="geometry" />
        </mxCell>

        <!-- Internet label -->
        <mxCell id="internet" value="Internet" style="text;html=1;align=center;verticalAlign=middle;fontSize=15;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="270" y="380" width="120" height="24" as="geometry" />
        </mxCell>

        <!-- bus collecting the three clients -->
        <mxCell id="bus" value="" style="endArrow=none;html=1;strokeColor=#3B1E66;strokeWidth=4;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="210" y="179" as="sourcePoint" /><mxPoint x="210" y="439" as="targetPoint" /></mxGeometry>
        </mxCell>
        <mxCell id="busm" value="" style="endArrow=none;html=1;strokeColor=#3B1E66;strokeWidth=4;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="mobile">
          <mxGeometry relative="1" as="geometry"><mxPoint x="210" y="179" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="busw" value="" style="endArrow=none;html=1;strokeColor=#3B1E66;strokeWidth=4;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="website">
          <mxGeometry relative="1" as="geometry"><mxPoint x="210" y="309" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="buss" value="" style="endArrow=none;html=1;strokeColor=#3B1E66;strokeWidth=4;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="services">
          <mxGeometry relative="1" as="geometry"><mxPoint x="210" y="439" as="targetPoint" /></mxGeometry></mxCell>

        <!-- big arrow 1: bus -> API Gateway -->
        <mxCell id="e1" value="" style="shape=flexArrow;html=1;startArrow=none;endArrow=block;fillColor=#3B1E66;strokeColor=#3B1E66;width=8;endWidth=22;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="212" y="309" as="sourcePoint" /><mxPoint x="430" y="309" as="targetPoint" /></mxGeometry>
        </mxCell>

        <!-- AWS Cloud + Secrets Manager box -->
        <mxCell id="cloud" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#232F3E;strokeWidth=1.5;" vertex="1" parent="1">
          <mxGeometry x="440" y="130" width="600" height="420" as="geometry" />
        </mxCell>
        <mxCell id="cloudicon" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;html=1;aspect=fixed;shape=mxgraph.aws4.aws_cloud_alt;" vertex="1" parent="1">
          <mxGeometry x="452" y="140" width="24" height="24" as="geometry" />
        </mxCell>
        <mxCell id="cloudlbl" value="AWS Cloud" style="text;html=1;align=left;verticalAlign=middle;fontSize=15;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="482" y="138" width="160" height="28" as="geometry" />
        </mxCell>
        <mxCell id="smlbl" value="AWS Secrets Manager" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="700" y="138" width="320" height="28" as="geometry" />
        </mxCell>

        <!-- Database credentials (top, secrets manager icon + key) -->
        <mxCell id="creds" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#7D8998;strokeColor=none;html=1;fontSize=13;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.secrets_manager;" vertex="1" parent="1">
          <mxGeometry x="800" y="200" width="58" height="58" as="geometry" />
        </mxCell>
        <mxCell id="credskey" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;html=1;fontSize=14;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.key_management_service;" vertex="1" parent="1">
          <mxGeometry x="880" y="204" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="credslbl" value="Database&#10;credentials" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;fontColor=#232F3E;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="940" y="204" width="100" height="50" as="geometry" />
        </mxCell>

        <!-- API Gateway -->
        <mxCell id="apigw" value="API&#10;Gateway" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#7D8998;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=14;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.api_gateway;" vertex="1" parent="1">
          <mxGeometry x="490" y="330" width="58" height="58" as="geometry" />
        </mxCell>
        <!-- Lambda -->
        <mxCell id="lambda" value="AWS&#10;Lambda&#10;function" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=14;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;" vertex="1" parent="1">
          <mxGeometry x="690" y="330" width="58" height="58" as="geometry" />
        </mxCell>
        <!-- RDS -->
        <mxCell id="rds" value="Amazon&#10;RDS&#10;database" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#7D8998;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=14;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.rds;" vertex="1" parent="1">
          <mxGeometry x="880" y="330" width="58" height="58" as="geometry" />
        </mxCell>

        <!-- flow arrows -->
        <!-- 2: apigw -> lambda (and back) -->
        <mxCell id="e2a" style="endArrow=block;html=1;strokeColor=#232F3E;strokeWidth=1.5;exitX=1;exitY=0.4;exitDx=0;exitDy=0;entryX=0;entryY=0.4;entryDx=0;entryDy=0;" edge="1" parent="1" source="apigw" target="lambda">
          <mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2b" style="endArrow=block;html=1;strokeColor=#232F3E;strokeWidth=1.5;exitX=0;exitY=0.6;exitDx=0;exitDy=0;entryX=1;entryY=0.6;entryDx=0;entryDy=0;" edge="1" parent="1" source="lambda" target="apigw">
          <mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- 4: lambda -> rds (and back) -->
        <mxCell id="e4a" style="endArrow=block;html=1;strokeColor=#232F3E;strokeWidth=1.5;exitX=1;exitY=0.4;exitDx=0;exitDy=0;entryX=0;entryY=0.4;entryDx=0;entryDy=0;" edge="1" parent="1" source="lambda" target="rds">
          <mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4b" style="endArrow=block;html=1;strokeColor=#232F3E;strokeWidth=1.5;exitX=0;exitY=0.6;exitDx=0;exitDy=0;entryX=1;entryY=0.6;entryDx=0;entryDy=0;" edge="1" parent="1" source="rds" target="lambda">
          <mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- 3: lambda <-> creds, rds <-> creds -->
        <mxCell id="e3a" style="endArrow=block;startArrow=block;html=1;strokeColor=#232F3E;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.7;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="lambda" target="creds">
          <mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3b" style="endArrow=block;startArrow=block;html=1;strokeColor=#232F3E;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.3;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="rds" target="creds">
          <mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- step badges -->
        <mxCell id="n1" value="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="215" y="294" width="32" height="32" as="geometry" /></mxCell>
        <mxCell id="n2" value="2" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="320" width="32" height="32" as="geometry" /></mxCell>
        <mxCell id="n3" value="3" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="788" y="270" width="32" height="32" as="geometry" /></mxCell>
        <mxCell id="n4" value="4" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="800" y="370" width="32" height="32" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
