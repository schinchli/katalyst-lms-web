        <!-- managed permissions label -->
        <mxCell id="mplbl" value="Managed&#10;permissions to&#10;AWS accounts" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontColor=#16191F;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="500" y="360" width="200" height="80" as="geometry" />
        </mxCell>

        <!-- AD Connector -->
        <mxCell id="adc" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;html=1;aspect=fixed;shape=mxgraph.aws4.ad_connector;" vertex="1" parent="1">
          <mxGeometry x="490" y="470" width="74" height="74" as="geometry" />
