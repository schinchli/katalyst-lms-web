        <mxCell id="orglbl" value="AWS accounts managed&#10;in AWS Organizations" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontColor=#16191F;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="560" y="236" width="300" height="50" as="geometry" />
