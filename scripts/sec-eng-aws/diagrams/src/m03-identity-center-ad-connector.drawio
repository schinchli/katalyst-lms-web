        <mxCell id="ouprod_f" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#ED7100;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="748" y="118" width="46" height="46" as="geometry" />
        </mxCell>
        <mxCell id="ouprod_i" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#ED7100;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="758" y="128" width="26" height="26" as="geometry" />
        </mxCell>
        <mxCell id="ouprodlbl" value="OU=Prod" style="text;html=1;align=center;verticalAlign=middle;fontSize=17;fontStyle=1;fontColor=#16191F;" vertex="1" parent="1">
