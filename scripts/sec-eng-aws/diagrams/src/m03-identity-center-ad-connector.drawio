        <mxCell id="iclbl" value="IAM Identity&#10;Center" style="text;html=1;align=center;verticalAlign=top;fontSize=16;fontColor=#16191F;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="682" y="558" width="120" height="50" as="geometry" />
