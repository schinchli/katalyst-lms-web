<mxfile host="app.diagrams.net">
  <diagram id="m03-ic-adconnector" name="Identity Center AD Connector">
    <mxGraphModel dx="1000" dy="640" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1340" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== Corporate data center ===== -->
        <mxCell id="dc" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#5A6B86;strokeWidth=2;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="20" y="150" width="360" height="320" as="geometry" />
        </mxCell>
        <mxCell id="dcicon" value="" style="shape=mxgraph.aws4.corporate_data_center;html=1;fillColor=#5A6B86;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="34" y="162" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="dctitle" value="Corporate data center" style="text;html=1;align=left;verticalAlign=middle;fontSize=18;fontColor=#16191F;" vertex="1" parent="1">
          <mxGeometry x="72" y="162" width="280" height="30" as="geometry" />
        </mxCell>

        <!-- on-prem users/groups -->
        <mxCell id="users" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;html=1;aspect=fixed;shape=mxgraph.aws4.users;" vertex="1" parent="1">
          <mxGeometry x="80" y="270" width="80" height="60" as="geometry" />
        </mxCell>
        <mxCell id="userslbl" value="On-premises&#10;users and&#10;groups" style="text;html=1;align=center;verticalAlign=top;fontSize=15;fontColor=#16191F;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="60" y="340" width="120" height="70" as="geometry" />
        </mxCell>

        <!-- Active Directory server -->
        <mxCell id="ad" value="" style="shape=mxgraph.aws4.traditional_server;html=1;fillColor=#232F3E;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="240" y="265" width="64" height="64" as="geometry" />
        </mxCell>
        <mxCell id="adlbl" value="Active&#10;Directory&#10;server" style="text;html=1;align=center;verticalAlign=top;fontSize=15;fontColor=#16191F;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="212" y="335" width="120" height="70" as="geometry" />
        </mxCell>

        <!-- ===== AWS Cloud ===== -->
        <mxCell id="cloud" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#16191F;strokeWidth=2;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="440" y="20" width="480" height="600" as="geometry" />
        </mxCell>
        <mxCell id="cloudicon" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;html=1;aspect=fixed;shape=mxgraph.aws4.aws_cloud_alt;" vertex="1" parent="1">
          <mxGeometry x="454" y="32" width="34" height="34" as="geometry" />
        </mxCell>
        <mxCell id="cloudtitle" value="AWS Cloud" style="text;html=1;align=left;verticalAlign=middle;fontSize=18;fontColor=#16191F;" vertex="1" parent="1">
          <mxGeometry x="496" y="32" width="200" height="34" as="geometry" />
        </mxCell>

        <!-- Organizations OU rounded container -->
        <mxCell id="org" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#16191F;strokeWidth=2;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="540" y="80" width="340" height="240" as="geometry" />
        </mxCell>
        <!-- OU=Dev : stacked orange account squares -->
        <mxCell id="oudev_b" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#ED7100;strokeWidth=3;" vertex="1" parent="1">
