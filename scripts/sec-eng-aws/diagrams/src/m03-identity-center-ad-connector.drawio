        <!-- ===== Right side apps ===== -->
        <mxCell id="biz" value="Business cloud applications" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#16191F;strokeWidth=2;arcSize=14;fontSize=16;fontColor=#16191F;align=center;" vertex="1" parent="1">
          <mxGeometry x="990" y="210" width="320" height="64" as="geometry" />
        </mxCell>
        <mxCell id="saml" value="Customer SAML-available&#10;applications" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#16191F;strokeWidth=2;arcSize=14;fontSize=16;fontColor=#16191F;align=center;" vertex="1" parent="1">
          <mxGeometry x="990" y="400" width="320" height="74" as="geometry" />
        </mxCell>

        <!-- ===== Numbered badges ===== -->
        <mxCell id="b1" value="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="80" width="34" height="34" as="geometry" />
        </mxCell>
        <mxCell id="b2" value="2" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="956" y="224" width="34" height="34" as="geometry" />
        </mxCell>
        <mxCell id="b3" value="3" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="956" y="414" width="34" height="34" as="geometry" />
        </mxCell>

        <!-- ===== Arrows ===== -->
        <!-- AD server -> AD Connector (diagonal across boundary) -->
        <mxCell id="ar1" style="endArrow=block;html=1;strokeColor=#16191F;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="305" y="300" as="sourcePoint" />
            <mxPoint x="487" y="500" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- AD Connector -> IAM Identity Center -->
        <mxCell id="ar2" style="endArrow=block;html=1;strokeColor=#16191F;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="566" y="507" as="sourcePoint" />
            <mxPoint x="698" y="507" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- IC -> Organizations (up) -->
        <mxCell id="ar3" style="endArrow=block;html=1;strokeColor=#16191F;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="745" y="468" as="sourcePoint" />
            <mxPoint x="720" y="322" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- IC -> Business cloud apps -->
        <mxCell id="ar4" style="endArrow=block;html=1;strokeColor=#16191F;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="784" y="500" as="sourcePoint" />
            <mxPoint x="988" y="258" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- IC -> SAML apps -->
        <mxCell id="ar5" style="endArrow=block;html=1;strokeColor=#16191F;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="784" y="512" as="sourcePoint" />
            <mxPoint x="988" y="437" as="targetPoint" />
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
