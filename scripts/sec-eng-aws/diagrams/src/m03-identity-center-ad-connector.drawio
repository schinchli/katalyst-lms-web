        <!-- IAM Identity Center -->
        <mxCell id="ic" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;html=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.single_sign_on;" vertex="1" parent="1">
          <mxGeometry x="700" y="470" width="84" height="84" as="geometry" />
