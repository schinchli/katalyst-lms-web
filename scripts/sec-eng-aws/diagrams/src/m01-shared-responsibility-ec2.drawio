<mxfile host="app.diagrams.net">
  <diagram id="m01-srm" name="Shared responsibility EC2">
    <mxGraphModel dx="1000" dy="700" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1040" pageHeight="660" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Responsibility varies based on AWS usage (Amazon EC2)" style="text;html=1;align=left;verticalAlign=middle;fontSize=24;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="30" y="20" width="980" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rule" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#8C4FFF;strokeColor=none;gradientColor=#E7157B;gradientDirection=east;" vertex="1" parent="1">
          <mxGeometry x="30" y="64" width="980" height="4" as="geometry" />
        </mxCell>

        <!-- Legend: Customer Responsibility (purple chevron) -->
        <mxCell id="legcust" value="Customer Responsibility" style="shape=step;perimeter=stepPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="220" height="38" as="geometry" />
        </mxCell>
        <!-- Legend: AWS Responsibility (orange chevron) -->
        <mxCell id="legaws" value="AWS Responsibility" style="shape=step;perimeter=stepPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#ED7100;strokeColor=none;fontColor=#FFFFFF;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="158" width="220" height="38" as="geometry" />
        </mxCell>

        <!-- Amazon EC2 label -->
        <mxCell id="ec2lbl" value="Amazon EC2" style="text;html=1;align=left;verticalAlign=middle;fontSize=15;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="60" y="330" width="170" height="24" as="geometry" />
        </mxCell>

        <!-- Stack of customer (purple) layers -->
        <mxCell id="L1" value="CUSTOMER DATA" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=#FFFFFF;strokeWidth=2;fontColor=#FFFFFF;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="110" width="380" height="44" as="geometry" />
        </mxCell>
        <mxCell id="L2" value="PLATFORM &amp; APPLICATION MANAGEMENT" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=#FFFFFF;strokeWidth=2;fontColor=#FFFFFF;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="154" width="380" height="44" as="geometry" />
        </mxCell>
        <mxCell id="L3" value="OS, NETWORK, FIREWALL CONFIGURATION" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=#FFFFFF;strokeWidth=2;fontColor=#FFFFFF;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="198" width="380" height="44" as="geometry" />
        </mxCell>
        <mxCell id="L4" value="NETWORK TRAFFIC PROTECTION" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=#FFFFFF;strokeWidth=2;fontColor=#FFFFFF;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="242" width="380" height="44" as="geometry" />
        </mxCell>
        <mxCell id="L5" value="SERVER-SIDE ENCRYPTION" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=#FFFFFF;strokeWidth=2;fontColor=#FFFFFF;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="286" width="380" height="44" as="geometry" />
        </mxCell>
        <mxCell id="L6" value="CLIENT-SIDE DATA ENCRYPTION / INTEGRITY" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=#FFFFFF;strokeWidth=2;fontColor=#FFFFFF;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="330" width="380" height="44" as="geometry" />
        </mxCell>

        <!-- AWS (orange) layers -->
        <mxCell id="L7" value="COMPUTE / STORAGE / DATABASE / NETWORK" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ED7100;strokeColor=#FFFFFF;strokeWidth=2;fontColor=#FFFFFF;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="374" width="380" height="44" as="geometry" />
        </mxCell>
        <mxCell id="L8" value="HARDWARE / AWS GLOBAL INFRASTRUCTURE" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ED7100;strokeColor=#FFFFFF;strokeWidth=2;fontColor=#FFFFFF;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="418" width="380" height="44" as="geometry" />
        </mxCell>

        <!-- Infrastructure Services label -->
        <mxCell id="infra" value="Infrastructure&#10;Services" style="text;html=1;align=center;verticalAlign=top;fontSize=14;fontColor=#232F3E;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="440" y="470" width="200" height="44" as="geometry" />
        </mxCell>

        <!-- Right side: CUSTOMER IAM (purple vertical) -->
        <mxCell id="custiam" value="CUSTOMER IAM" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=#FFFFFF;strokeWidth=2;fontColor=#FFFFFF;fontSize=13;fontStyle=1;horizontal=0;" vertex="1" parent="1">
          <mxGeometry x="745" y="110" width="44" height="264" as="geometry" />
        </mxCell>
        <!-- AWS IAM (orange vertical) -->
        <mxCell id="awsiam" value="AWS IAM" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ED7100;strokeColor=#FFFFFF;strokeWidth=2;fontColor=#FFFFFF;fontSize=13;fontStyle=1;horizontal=0;" vertex="1" parent="1">
          <mxGeometry x="745" y="374" width="44" height="88" as="geometry" />
        </mxCell>

        <!-- Right annotation -->
        <mxCell id="annot" value="More Customizable&#10;+&#10;More Customer&#10;Responsibility" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontColor=#232F3E;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="820" y="180" width="200" height="110" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
