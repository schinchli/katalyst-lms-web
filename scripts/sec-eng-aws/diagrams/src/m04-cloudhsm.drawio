<mxfile host="app.diagrams.net">
  <diagram id="m04-hsm" name="Using CloudHSM">
    <mxGraphModel dx="1000" dy="640" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1040" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Using CloudHSM" style="text;html=1;align=left;verticalAlign=middle;fontSize=24;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="30" y="20" width="600" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rule" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#8C4FFF;strokeColor=none;gradientColor=#E7157B;gradientDirection=east;" vertex="1" parent="1">
          <mxGeometry x="30" y="64" width="980" height="4" as="geometry" />
        </mxCell>

        <!-- Management Console (top left) -->
        <mxCell id="console" value="AWS Management&#10;Console" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=14;aspect=fixed;shape=mxgraph.aws4.management_console;" vertex="1" parent="1">
          <mxGeometry x="110" y="160" width="70" height="70" as="geometry" />
        </mxCell>
        <!-- CLI (bottom left) -->
        <mxCell id="cli" value="AWS Command Line&#10;Interface (AWS CLI)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=14;aspect=fixed;shape=mxgraph.aws4.command_line_interface;" vertex="1" parent="1">
          <mxGeometry x="110" y="310" width="70" height="70" as="geometry" />
        </mxCell>

        <!-- CloudHSM (center) -->
        <mxCell id="hsm" value="CloudHSM" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;verticalLabelPosition=top;verticalAlign=bottom;align=center;html=1;fontSize=15;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudhsm;" vertex="1" parent="1">
          <mxGeometry x="470" y="180" width="70" height="70" as="geometry" />
        </mxCell>

        <!-- Your applications (below center) -->
        <mxCell id="apps" value="Your applications" style="text;html=1;align=center;verticalAlign=top;fontSize=15;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="420" y="470" width="170" height="24" as="geometry" />
        </mxCell>
        <mxCell id="appsbox" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="455" y="400" width="100" height="64" as="geometry" />
        </mxCell>
        <mxCell id="ai1" value="" style="ellipse;html=1;fillColor=none;strokeColor=#232F3E;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="455" y="400" width="44" height="30" as="geometry" /></mxCell>
        <mxCell id="ai2" value="" style="shape=cylinder;html=1;fillColor=none;strokeColor=#232F3E;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="511" y="400" width="44" height="30" as="geometry" /></mxCell>
        <mxCell id="ai3" value="" style="rounded=0;html=1;fillColor=none;strokeColor=#232F3E;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="455" y="434" width="44" height="30" as="geometry" /></mxCell>
        <mxCell id="ai4" value="" style="rounded=0;html=1;fillColor=none;strokeColor=#232F3E;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="511" y="434" width="44" height="30" as="geometry" /></mxCell>

        <!-- CloudWatch (top right) -->
        <mxCell id="cw" value="Amazon CloudWatch" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#E7157B;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=14;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudwatch;" vertex="1" parent="1">
          <mxGeometry x="810" y="160" width="70" height="70" as="geometry" />
        </mxCell>
        <!-- CloudTrail (bottom right) -->
        <mxCell id="ct" value="CloudTrail" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#E7157B;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=14;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudtrail;" vertex="1" parent="1">
          <mxGeometry x="810" y="320" width="70" height="70" as="geometry" />
        </mxCell>

        <!-- edges -->
        <!-- console -> hsm (joins) -->
        <mxCell id="e_con" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=3;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.45;entryDx=0;entryDy=0;" edge="1" parent="1" source="console" target="hsm">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="350" y="195" /><mxPoint x="350" y="208" /></Array>
          </mxGeometry></mxCell>
        <mxCell id="e_cli" style="endArrow=none;html=1;strokeColor=#3B1E66;strokeWidth=3;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="cli">
          <mxGeometry relative="1" as="geometry"><mxPoint x="350" y="345" as="targetPoint" />
            <Array as="points"><mxPoint x="350" y="345" /><mxPoint x="350" y="208" /></Array>
          </mxGeometry></mxCell>

        <!-- hsm <-> apps (vertical double) -->
        <mxCell id="e_apps" style="endArrow=block;startArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=3;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="hsm" target="ai1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="505" y="380" /></Array>
          </mxGeometry></mxCell>

        <!-- hsm -> cloudwatch -->
        <mxCell id="e_cw" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=3;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="hsm" target="cw">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="680" y="215" /><mxPoint x="680" y="195" /></Array>
          </mxGeometry></mxCell>
        <!-- hsm -> cloudtrail (branch down) -->
        <mxCell id="e_ct" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=3;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" target="ct">
          <mxGeometry relative="1" as="geometry"><mxPoint x="680" y="215" as="sourcePoint" />
            <Array as="points"><mxPoint x="680" y="355" /></Array>
          </mxGeometry></mxCell>

        <!-- step badges -->
        <mxCell id="n1" value="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="335" y="195" width="30" height="30" as="geometry" /></mxCell>
        <mxCell id="n2" value="2" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="490" y="300" width="30" height="30" as="geometry" /></mxCell>
        <mxCell id="n3" value="3" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="665" y="195" width="30" height="30" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
