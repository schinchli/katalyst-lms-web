<mxfile host="app.diagrams.net">
  <diagram id="m02-perm-boundary" name="Permissions boundary effective">
    <mxGraphModel dx="800" dy="500" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="720" pageHeight="430" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Identity-based policy box (top-right, purple outline) -->
        <mxCell id="idpolicy" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7B2D5E;strokeWidth=5;arcSize=14;" vertex="1" parent="1">
          <mxGeometry x="230" y="20" width="380" height="280" as="geometry" />
        </mxCell>
        <mxCell id="idpolicylbl" value="Identity-based&lt;br&gt;policy" style="text;html=1;align=center;verticalAlign=middle;fontSize=22;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="360" y="35" width="220" height="70" as="geometry" />
        </mxCell>
        <!-- black check inside id policy (top) -->
        <mxCell id="idcheck" value="&#10003;" style="text;html=1;align=center;verticalAlign=middle;fontSize=44;fontStyle=1;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="250" y="60" width="70" height="60" as="geometry" />
        </mxCell>

        <!-- Permissions boundary box (bottom-left, purple outline) -->
        <mxCell id="boundary" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7B2D5E;strokeWidth=5;arcSize=14;" vertex="1" parent="1">
          <mxGeometry x="20" y="140" width="380" height="270" as="geometry" />
        </mxCell>
        <mxCell id="boundarylbl" value="Permissions&lt;br&gt;boundary" style="text;html=1;align=center;verticalAlign=middle;fontSize=22;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="36" y="320" width="220" height="70" as="geometry" />
        </mxCell>
        <!-- black check inside boundary (bottom) -->
        <mxCell id="bcheck" value="&#10003;" style="text;html=1;align=center;verticalAlign=middle;fontSize=44;fontStyle=1;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="300" y="320" width="70" height="60" as="geometry" />
        </mxCell>

        <!-- Intersection (filled dark purple, on top) -->
        <mxCell id="intersect" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7B2D5E;strokeColor=none;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="230" y="140" width="170" height="160" as="geometry" />
        </mxCell>
        <!-- three white checks in intersection -->
        <mxCell id="wc1" value="&#10003;" style="text;html=1;align=center;verticalAlign=middle;fontSize=40;fontStyle=1;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="280" y="150" width="70" height="48" as="geometry" />
        </mxCell>
        <mxCell id="wc2" value="&#10003;" style="text;html=1;align=center;verticalAlign=middle;fontSize=40;fontStyle=1;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="280" y="196" width="70" height="48" as="geometry" />
        </mxCell>
        <mxCell id="wc3" value="&#10003;" style="text;html=1;align=center;verticalAlign=middle;fontSize=40;fontStyle=1;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="280" y="242" width="70" height="48" as="geometry" />
        </mxCell>

        <!-- Effective permissions arrow pointing into intersection -->
        <mxCell id="effarrow" value="" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=8;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="250" as="sourcePoint" />
            <mxPoint x="405" y="250" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="efflbl" value="Effective permissions" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontColor=#4B0082;" vertex="1" parent="1">
          <mxGeometry x="380" y="300" width="320" height="30" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
