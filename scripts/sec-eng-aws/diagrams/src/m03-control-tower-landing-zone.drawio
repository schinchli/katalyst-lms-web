<mxfile host="app.diagrams.net">
  <diagram id="m03-ct-landing-zone" name="Control Tower landing zone">
    <mxGraphModel dx="1000" dy="520" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="720" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- outer red boundary -->
        <mxCell id="bound" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#DD344C;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="960" height="680" as="geometry" />
        </mxCell>

        <!-- Unified management account (top left) -->
        <mxCell id="mgmt" value="Unified&lt;br&gt;management account" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.organizations_account;sketch=0;outlineConnect=0;fillColor=#CD2264;strokeColor=none;verticalLabelPosition=right;verticalAlign=middle;align=left;labelPosition=right;html=1;fontSize=14;fontColor=#232F3E;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="46" height="46" as="geometry" />
        </mxCell>

        <!-- AWS Control Tower (top center) -->
        <mxCell id="ct" value="AWS Control Tower" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.control_tower;sketch=0;outlineConnect=0;fillColor=#CD2264;strokeColor=none;verticalLabelPosition=right;verticalAlign=middle;align=left;labelPosition=right;html=1;fontSize=14;fontColor=#232F3E;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="450" y="40" width="52" height="52" as="geometry" />
        </mxCell>

        <!-- AWS Organizations (left) -->
        <mxCell id="org" value="AWS Organizations" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.organizations;sketch=0;outlineConnect=0;fillColor=#CD2264;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=14;fontColor=#232F3E;" vertex="1" parent="1">
