<mxfile host="app.diagrams.net">
  <diagram id="m06-vpc-peering" name="VPC peering">
    <mxGraphModel dx="1000" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1020" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="VPC peering use case" style="text;html=1;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="30" y="16" width="500" height="36" as="geometry" />
        </mxCell>

        <!-- Account 1 box -->
        <mxCell id="acc1" value="AWS Account 1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#232F3E;verticalAlign=top;align=left;spacingLeft=30;spacingTop=8;fontSize=13;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="200" y="90" width="230" height="180" as="geometry" />
        </mxCell>
        <mxCell id="acc1lbl" value="aws" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=none;fontColor=#FFFFFF;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="208" y="98" width="22" height="18" as="geometry" />
        </mxCell>
        <mxCell id="vpc1" value="VPC&lt;br&gt;&lt;br&gt;Regulated&lt;br&gt;workload:&lt;br&gt;Financials" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1B660F;verticalAlign=top;align=center;spacingTop=6;fontSize=12;fontColor=#1B660F;" vertex="1" parent="1">
          <mxGeometry x="220" y="130" width="190" height="120" as="geometry" />
        </mxCell>

        <!-- Account 2 box -->
        <mxCell id="acc2" value="AWS Account 2" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#232F3E;verticalAlign=top;align=left;spacingLeft=30;spacingTop=8;fontSize=13;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="600" y="90" width="230" height="180" as="geometry" />
        </mxCell>
        <mxCell id="acc2lbl" value="aws" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=none;fontColor=#FFFFFF;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="608" y="98" width="22" height="18" as="geometry" />
        </mxCell>
        <mxCell id="vpc2" value="VPC&lt;br&gt;&lt;br&gt;Regulated&lt;br&gt;workload:&lt;br&gt;Confidential" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1B660F;verticalAlign=top;align=center;spacingTop=6;fontSize=12;fontColor=#1B660F;" vertex="1" parent="1">
          <mxGeometry x="620" y="130" width="190" height="120" as="geometry" />
        </mxCell>

        <!-- Account 3 box -->
        <mxCell id="acc3" value="AWS Account 3" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#232F3E;verticalAlign=top;align=left;spacingLeft=30;spacingTop=8;fontSize=13;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="390" y="340" width="240" height="200" as="geometry" />
        </mxCell>
        <mxCell id="acc3lbl" value="aws" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=none;fontColor=#FFFFFF;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="398" y="348" width="22" height="18" as="geometry" />
        </mxCell>
        <mxCell id="vpc3" value="VPC&lt;br&gt;&lt;br&gt;Central VPC&lt;br&gt;(log processing)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1B660F;verticalAlign=top;align=center;spacingTop=6;fontSize=12;fontColor=#1B660F;" vertex="1" parent="1">
          <mxGeometry x="410" y="380" width="200" height="140" as="geometry" />
        </mxCell>

        <!-- VPC peer left -->
        <mxCell id="peerL" value="VPC&lt;br&gt;peer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#8C4FFF;strokeColor=none;fontColor=#232F3E;fontSize=12;verticalLabelPosition=bottom;verticalAlign=top;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="270" y="400" width="48" height="48" as="geometry" />
        </mxCell>
        <!-- VPC peer right -->
        <mxCell id="peerR" value="VPC&lt;br&gt;peer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#8C4FFF;strokeColor=none;fontColor=#232F3E;fontSize=12;verticalLabelPosition=bottom;verticalAlign=top;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="700" y="400" width="48" height="48" as="geometry" />
        </mxCell>

        <!-- Arrows: VPC1 down to peerL, peerL into VPC3 -->
        <mxCell id="a_v1_pl" style="endArrow=block;html=1;strokeColor=#232F3E;strokeWidth=3;exitX=0.05;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="vpc1" target="peerL">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="230" y="424" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="a_pl_v3" style="endArrow=block;html=1;strokeColor=#232F3E;strokeWidth=3;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.6;entryDx=0;entryDy=0;" edge="1" parent="1" source="peerL" target="vpc3">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="360" y="424" /><mxPoint x="360" y="464" /></Array></mxGeometry>
        </mxCell>

        <!-- VPC2 down to peerR, peerR into VPC3 -->
        <mxCell id="a_v2_pr" style="endArrow=block;html=1;strokeColor=#232F3E;strokeWidth=3;exitX=0.95;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="vpc2" target="peerR">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="800" y="424" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="a_pr_v3" style="endArrow=block;html=1;strokeColor=#232F3E;strokeWidth=3;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.6;entryDx=0;entryDy=0;" edge="1" parent="1" source="peerR" target="vpc3">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="660" y="424" /><mxPoint x="660" y="464" /></Array></mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
