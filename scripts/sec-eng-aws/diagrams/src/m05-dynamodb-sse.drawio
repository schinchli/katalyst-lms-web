<mxfile host="app.diagrams.net">
  <diagram id="m05-dynamodb-sse" name="DynamoDB SSE">
    <mxGraphModel dx="1000" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1020" pageHeight="540" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Amazon DynamoDB SSE example" style="text;html=1;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="30" y="16" width="600" height="36" as="geometry" />
        </mxCell>

        <!-- Amazon DynamoDB -->
        <mxCell id="ddb" value="Amazon&lt;br&gt;DynamoDB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4053D6;strokeColor=none;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="110" width="96" height="56" as="geometry" />
        </mxCell>

        <!-- DynamoDB encryption algorithm (gear) -->
        <mxCell id="algo" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4053D6;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="430" y="110" width="56" height="56" as="geometry" />
        </mxCell>
        <mxCell id="algolab" value="DynamoDB&lt;br&gt;encryption algorithm" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="378" y="66" width="160" height="36" as="geometry" />
        </mxCell>
        <!-- Table key label -->
        <mxCell id="tklab" value="Table key" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="490" y="150" width="80" height="20" as="geometry" />
        </mxCell>

        <!-- AWS KMS -->
        <mxCell id="kms" value="AWS KMS" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.key_management_service;" vertex="1" parent="1">
          <mxGeometry x="820" y="108" width="52" height="52" as="geometry" />
        </mxCell>

        <!-- Step 1 -->
        <mxCell id="b1" value="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="590" y="92" width="24" height="24" as="geometry" /></mxCell>
        <mxCell id="t1" value="A table key is generated by&lt;br&gt;AWS KMS." style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="620" y="92" width="220" height="40" as="geometry" />
        </mxCell>

        <!-- Step 2 -->
        <mxCell id="b2" value="2" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60" y="270" width="24" height="24" as="geometry" /></mxCell>
        <mxCell id="t2" value="Data encryption keys&lt;br&gt;generated by DynamoDB and&lt;br&gt;encrypted with table key." style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="30" y="296" width="220" height="56" as="geometry" />
        </mxCell>

        <!-- Step 3 -->
        <mxCell id="b3" value="3" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="640" y="266" width="24" height="24" as="geometry" /></mxCell>
        <mxCell id="t3lab" value="AWS KMS Key" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="760" y="220" width="140" height="20" as="geometry" />
        </mxCell>
        <mxCell id="t3" value="KMS uses an AWS KMS Key&lt;br&gt;to encrypt the table key." style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="672" y="266" width="240" height="40" as="geometry" />
        </mxCell>

        <!-- Table container -->
        <mxCell id="tablebox" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#7AA7C7;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="120" y="360" width="540" height="130" as="geometry" />
        </mxCell>
        <!-- Table icon -->
        <mxCell id="tableicon" value="Table" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4053D6;strokeColor=none;fontColor=#FFFFFF;fontSize=11;fontStyle=1;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="150" y="420" width="50" height="40" as="geometry" />
        </mxCell>

        <!-- locks (data keys) row -->
        <mxCell id="lock1" value="" style="shape=mxgraph.basic.lock;html=1;fillColor=#DD344C;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="270" y="250" width="22" height="26" as="geometry" /></mxCell>
        <mxCell id="lock2" value="" style="shape=mxgraph.basic.lock;html=1;fillColor=#DD344C;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="330" y="250" width="22" height="26" as="geometry" /></mxCell>
        <mxCell id="lock3" value="" style="shape=mxgraph.basic.lock;html=1;fillColor=#DD344C;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="390" y="250" width="22" height="26" as="geometry" /></mxCell>
        <mxCell id="lock4" value="" style="shape=mxgraph.basic.lock;html=1;fillColor=#DD344C;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="450" y="250" width="22" height="26" as="geometry" /></mxCell>

        <!-- item labels -->
        <mxCell id="it1" value="Item 1" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1"><mxGeometry x="250" y="466" width="64" height="18" as="geometry" /></mxCell>
        <mxCell id="it23" value="Item 2, 3" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1"><mxGeometry x="300" y="486" width="70" height="18" as="geometry" /></mxCell>
        <mxCell id="it4" value="Item 4" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1"><mxGeometry x="370" y="466" width="64" height="18" as="geometry" /></mxCell>
        <mxCell id="it57" value="Item 5-7" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1"><mxGeometry x="430" y="466" width="70" height="18" as="geometry" /></mxCell>
        <!-- lock inside table (encrypted table key) -->
        <mxCell id="lock_table" value="" style="shape=mxgraph.basic.lock;html=1;fillColor=#DD344C;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="530" y="430" width="22" height="26" as="geometry" /></mxCell>

        <!-- Arrows -->
        <!-- ddb -> algo -->
        <mxCell id="a_ddb_algo" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="ddb" target="algo"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- kms -> table key (algo) step1 -->
        <mxCell id="a_kms_algo" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=2;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="kms" target="algo"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- algo down splits into locks (step2) -->
        <mxCell id="a_algo_l1" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="algo" target="lock1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="281" y="220" /></Array></mxGeometry></mxCell>
        <mxCell id="a_algo_l2" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="algo" target="lock2"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="341" y="225" /></Array></mxGeometry></mxCell>
        <mxCell id="a_algo_l3" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="algo" target="lock3"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="401" y="230" /></Array></mxGeometry></mxCell>
        <mxCell id="a_algo_l4" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="algo" target="lock4"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="461" y="235" /></Array></mxGeometry></mxCell>
        <!-- locks down into table -->
        <mxCell id="a_l1_t" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="lock1" target="tablebox"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_l2_t" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.4;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="lock2" target="tablebox"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_l3_t" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.55;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="lock3" target="tablebox"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_l4_t" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.7;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="lock4" target="tablebox"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- step3: kms encrypts table key (arrow from kms key text area to lock_table) -->
        <mxCell id="a_kms_locktable" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=2;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="t3lab" target="lock_table"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="610" y="443" /></Array></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
