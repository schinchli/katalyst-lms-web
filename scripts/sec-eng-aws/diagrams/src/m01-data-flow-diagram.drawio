<mxfile host="app.diagrams.net">
  <diagram id="m01-dfd" name="Data flow diagram example">
    <mxGraphModel dx="1000" dy="700" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1040" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Data flow diagram example" style="text;html=1;align=left;verticalAlign=middle;fontSize=26;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="30" y="20" width="600" height="40" as="geometry" />
        </mxCell>

        <!-- VPC outer boundary -->
        <mxCell id="vpc" value="VPC" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#7AA116;strokeWidth=2;verticalAlign=top;align=left;fontColor=#7AA116;fontSize=15;fontStyle=1;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="120" y="110" width="890" height="470" as="geometry" />
        </mxCell>

        <!-- VPC CIDR label -->
        <mxCell id="cidr" value="VPC 10.0.0.0/16" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="180" y="540" width="200" height="24" as="geometry" />
        </mxCell>

        <!-- Availability Zone A boundary (dashed blue) -->
        <mxCell id="az" value="Availability Zone A" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#00A1C9;strokeWidth=1.5;dashed=1;verticalAlign=top;align=center;fontColor=#232F3E;fontSize=15;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="180" y="150" width="800" height="370" as="geometry" />
        </mxCell>

        <!-- User -->
        <mxCell id="user" value="User" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=13;aspect=fixed;shape=mxgraph.aws4.user;" vertex="1" parent="1">
          <mxGeometry x="40" y="170" width="46" height="46" as="geometry" />
        </mxCell>

        <!-- Internet gateway (no reliable sprite -> labeled box) -->
        <mxCell id="igw" value="Internet&#10;gateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#8C4FFF;strokeWidth=2;fontColor=#232F3E;fontSize=13;verticalLabelPosition=bottom;verticalAlign=top;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="360" width="46" height="46" as="geometry" />
        </mxCell>
        <mxCell id="igwicon" value="" style="ellipse;html=1;fillColor=none;strokeColor=#8C4FFF;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="48" y="368" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- Public subnet -->
        <mxCell id="pub" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="240" y="270" width="220" height="220" as="geometry" />
        </mxCell>
        <mxCell id="publbl" value="Public subnet" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="280" y="280" width="160" height="24" as="geometry" />
        </mxCell>
        <mxCell id="publock" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7AA116;strokeColor=none;fontColor=#FFFFFF;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="252" y="280" width="22" height="22" as="geometry" />
        </mxCell>

        <!-- Web Server (EC2) -->
        <mxCell id="web" value="Web Server" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=13;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ec2;" vertex="1" parent="1">
          <mxGeometry x="320" y="360" width="56" height="56" as="geometry" />
        </mxCell>

        <!-- Private subnet 1 -->
        <mxCell id="priv1" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E6F2F8;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="500" y="270" width="220" height="220" as="geometry" />
        </mxCell>
        <mxCell id="priv1lbl" value="Private subnet" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="540" y="280" width="160" height="24" as="geometry" />
        </mxCell>
        <mxCell id="priv1lock" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00A1C9;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="512" y="280" width="22" height="22" as="geometry" />
        </mxCell>

        <!-- Application Server (EC2) -->
        <mxCell id="app" value="Application&#10;Server" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=13;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ec2;" vertex="1" parent="1">
          <mxGeometry x="582" y="360" width="56" height="56" as="geometry" />
        </mxCell>

        <!-- Private subnet 2 -->
        <mxCell id="priv2" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E6F2F8;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="760" y="270" width="220" height="220" as="geometry" />
        </mxCell>
        <mxCell id="priv2lbl" value="Private subnet" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="800" y="280" width="160" height="24" as="geometry" />
        </mxCell>
        <mxCell id="priv2lock" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00A1C9;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="772" y="280" width="22" height="22" as="geometry" />
        </mxCell>

        <!-- Transaction processing database -->
        <mxCell id="db" value="Transaction&#10;processing&#10;database" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#4D72F3;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=13;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.database;" vertex="1" parent="1">
          <mxGeometry x="842" y="360" width="56" height="56" as="geometry" />
        </mxCell>

        <!-- letter badges A B C -->
        <mxCell id="bA" value="A" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="370" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="bB" value="B" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="468" y="370" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="bC" value="C" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="728" y="370" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- number badges 1 2 3 -->
        <mxCell id="n1" value="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="200" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="n2" value="2" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="595" y="455" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="n3" value="3" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="930" y="200" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- edges -->
        <!-- user -> igw (vertical line) -->
        <mxCell id="e_user_igw" style="endArrow=none;html=1;strokeColor=#232F3E;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="user" target="igw">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- A: igw <-> web -->
        <mxCell id="e_igw_web" style="endArrow=block;startArrow=block;html=1;strokeColor=#232F3E;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="igw" target="web">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- B: web <-> app -->
        <mxCell id="e_web_app" style="endArrow=block;startArrow=block;html=1;strokeColor=#232F3E;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="web" target="app">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- C: app <-> db -->
        <mxCell id="e_app_db" style="endArrow=block;startArrow=block;html=1;strokeColor=#232F3E;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="app" target="db">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
