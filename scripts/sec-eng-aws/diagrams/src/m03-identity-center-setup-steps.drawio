<mxfile host="app.diagrams.net">
  <diagram id="m03-ic-setup" name="Identity Center setup steps">
    <mxGraphModel dx="1000" dy="520" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1040" pageHeight="320" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Headings -->
        <mxCell id="h1" value="Turn on the&#10;service." style="text;html=1;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;fontColor=#16191F;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="20" y="14" width="200" height="44" as="geometry" />
        </mxCell>
        <mxCell id="h2" value="Choose your&#10;identity source." style="text;html=1;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;fontColor=#16191F;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="280" y="14" width="200" height="44" as="geometry" />
        </mxCell>
        <mxCell id="h3" value="Set up access to&#10;accounts." style="text;html=1;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;fontColor=#16191F;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="540" y="14" width="200" height="44" as="geometry" />
        </mxCell>
        <mxCell id="h4" value="Set up access to&#10;applications." style="text;html=1;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;fontColor=#16191F;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="800" y="14" width="200" height="44" as="geometry" />
        </mxCell>

        <!-- Step 1: IAM Identity Center icon -->
        <mxCell id="i1" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;html=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.single_sign_on;" vertex="1" parent="1">
          <mxGeometry x="78" y="68" width="78" height="78" as="geometry" />
        </mxCell>

        <!-- Step 2: directory icons (rendered as a labeled red box approx Active Directory) -->
        <mxCell id="i2" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;html=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.directory_service;" vertex="1" parent="1">
          <mxGeometry x="341" y="68" width="78" height="78" as="geometry" />
        </mxCell>

        <!-- Step 3: organizations -->
        <mxCell id="i3" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#E7157B;strokeColor=none;html=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.organizations;" vertex="1" parent="1">
          <mxGeometry x="601" y="68" width="78" height="78" as="geometry" />
        </mxCell>

        <!-- Step 4: applications/laptop -->
        <mxCell id="i4" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#16191F;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="861" y="72" width="78" height="58" as="geometry" />
        </mxCell>
        <mxCell id="i4b" value="&#10003;&#10003;&#10003;" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontColor=#16191F;" vertex="1" parent="1">
          <mxGeometry x="861" y="72" width="78" height="58" as="geometry" />
        </mxCell>

        <!-- captions -->
        <mxCell id="c1" value="Turn on IAM Identity&#10;Center in&#10;your organization." style="text;html=1;align=center;verticalAlign=top;fontSize=12.5;fontColor=#16191F;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="20" y="160" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="c2" value="Connect to your&#10;on-premises Active&#10;Directory or use a&#10;built-in directory." style="text;html=1;align=center;verticalAlign=top;fontSize=12.5;fontColor=#16191F;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="280" y="160" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="c3" value="Grant users and&#10;groups IAM Identity&#10;Center access to&#10;specific AWS&#10;accounts." style="text;html=1;align=center;verticalAlign=top;fontSize=12.5;fontColor=#16191F;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="540" y="160" width="200" height="100" as="geometry" />
        </mxCell>
        <mxCell id="c4" value="Permit users to access&#10;applications from&#10;within their portal." style="text;html=1;align=center;verticalAlign=top;fontSize=12.5;fontColor=#16191F;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="800" y="160" width="200" height="80" as="geometry" />
        </mxCell>

        <!-- arrows between steps -->
        <mxCell id="a1" style="endArrow=block;html=1;strokeColor=#7C3AED;strokeWidth=3;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="232" y="107" as="sourcePoint" />
            <mxPoint x="278" y="107" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="a2" style="endArrow=block;html=1;strokeColor=#7C3AED;strokeWidth=3;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="492" y="107" as="sourcePoint" />
            <mxPoint x="538" y="107" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="a3" style="endArrow=block;html=1;strokeColor=#7C3AED;strokeWidth=3;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="752" y="107" as="sourcePoint" />
            <mxPoint x="798" y="107" as="targetPoint" />
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
