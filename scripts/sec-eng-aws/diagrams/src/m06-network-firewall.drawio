        <!-- Firewall endpoint label -->
        <mxCell id="fwep" value="Firewall&lt;br&gt;endpoint" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="300" y="250" width="70" height="40" as="geometry" />
        </mxCell>

        <!-- Inner dashed box: policy/block/monitor -->
        <mxCell id="innerbox" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1B660F;dashed=1;" vertex="1" parent="1">
