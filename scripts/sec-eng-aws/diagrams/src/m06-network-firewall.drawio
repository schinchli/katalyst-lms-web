          <mxGeometry x="400" y="412" width="360" height="22" as="geometry" />
        </mxCell>

        <!-- bottom row: S3, CloudWatch, partner -->
        <mxCell id="s3" value="Amazon Simple Storage&lt;br&gt;Service (Amazon S3)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#7AA116;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;" vertex="1" parent="1">
