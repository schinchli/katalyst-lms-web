        <mxCell id="cw" value="Amazon CloudWatch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7157B;strokeColor=none;fontColor=#232F3E;fontSize=11;verticalLabelPosition=bottom;verticalAlign=top;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="440" width="48" height="48" as="geometry" />
        </mxCell>
        <mxCell id="partner" value="Integrated&lt;br&gt;Partner Solutions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=none;fontColor=#232F3E;fontSize=11;verticalLabelPosition=bottom;verticalAlign=top;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="440" width="48" height="48" as="geometry" />
        </mxCell>

        <!-- Arrows -->
        <mxCell id="a_left_vpc" style="endArrow=block;html=1;strokeColor=#232F3E;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="leftbox" target="fwep"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_vpc_subnet" style="endArrow=block;startArrow=block;html=1;strokeColor=#232F3E;strokeWidth=2;exitX=1;exitY=0.45;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="innerbox" target="priv"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- monitor -> publish (down) -->
        <mxCell id="a_mon_s3" style="endArrow=block;html=1;strokeColor=#232F3E;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="monitor" target="cw"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="670" y="430" /><mxPoint x="564" y="430" /></Array></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
