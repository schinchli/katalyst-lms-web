<mxfile host="app.diagrams.net">
  <diagram id="m06-network-firewall" name="Network Firewall">
    <mxGraphModel dx="1000" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1020" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Network Firewall overview" style="text;html=1;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="30" y="16" width="600" height="36" as="geometry" />
        </mxCell>

        <!-- Manage Multiple Firewall Deployments heading -->
        <mxCell id="mngtitle" value="Manage Multiple Firewall Deployments" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="300" y="60" width="420" height="24" as="geometry" />
        </mxCell>

        <!-- Left gateway stack box -->
        <mxCell id="leftbox" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F2F2F2;strokeColor=#CCCCCC;" vertex="1" parent="1">
          <mxGeometry x="30" y="100" width="180" height="380" as="geometry" />
        </mxCell>
        <mxCell id="tgw" value="AWS Transit Gateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#8C4FFF;strokeColor=none;fontColor=#232F3E;fontSize=11;verticalLabelPosition=bottom;verticalAlign=top;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="116" width="42" height="42" as="geometry" />
        </mxCell>
        <mxCell id="vpngw" value="VPN Gateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#8C4FFF;strokeColor=none;fontColor=#232F3E;fontSize=11;verticalLabelPosition=bottom;verticalAlign=top;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="206" width="42" height="42" as="geometry" />
        </mxCell>
        <mxCell id="dx" value="AWS Direct Connect" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#8C4FFF;strokeColor=none;fontColor=#232F3E;fontSize=11;verticalLabelPosition=bottom;verticalAlign=top;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="296" width="42" height="42" as="geometry" />
        </mxCell>
        <mxCell id="igw" value="Internet gateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#8C4FFF;strokeColor=none;fontColor=#232F3E;fontSize=11;verticalLabelPosition=bottom;verticalAlign=top;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="386" width="42" height="42" as="geometry" />
        </mxCell>

        <!-- AWS Organizations / Firewall Manager -->
        <mxCell id="orgs" value="AWS Organizations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7157B;strokeColor=none;fontColor=#232F3E;fontSize=11;verticalLabelPosition=bottom;verticalAlign=top;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="96" width="48" height="48" as="geometry" />
        </mxCell>
        <mxCell id="fwm" value="Firewall Manager" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DD344C;strokeColor=none;fontColor=#232F3E;fontSize=11;verticalLabelPosition=bottom;verticalAlign=top;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="96" width="48" height="48" as="geometry" />
        </mxCell>

        <!-- VPC green container -->
        <mxCell id="vpc" value="VPC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1B660F;verticalAlign=top;align=left;spacingLeft=24;spacingTop=6;fontSize=13;fontStyle=1;fontColor=#1B660F;" vertex="1" parent="1">
          <mxGeometry x="300" y="170" width="560" height="240" as="geometry" />
