<mxfile host="app.diagrams.net">
  <diagram id="m04-ebs" name="KMS with EBS">
    <mxGraphModel dx="1000" dy="640" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1040" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="AWS KMS example with Amazon EBS" style="text;html=1;align=left;verticalAlign=middle;fontSize=24;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="30" y="20" width="900" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rule" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#8C4FFF;strokeColor=none;gradientColor=#E7157B;gradientDirection=east;" vertex="1" parent="1">
          <mxGeometry x="30" y="64" width="980" height="4" as="geometry" />
        </mxCell>

        <!-- EBS volume (top left) -->
        <mxCell id="ebs" value="Amazon EBS&#10;volume" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#1B9E77;strokeColor=none;verticalLabelPosition=top;verticalAlign=bottom;align=center;html=1;fontSize=13;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elastic_block_store;" vertex="1" parent="1">
          <mxGeometry x="170" y="140" width="58" height="58" as="geometry" />
        </mxCell>

        <!-- Server (bottom left) -->
        <mxCell id="server" value="Server" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=13;aspect=fixed;shape=mxgraph.aws4.traditional_server;" vertex="1" parent="1">
          <mxGeometry x="170" y="350" width="58" height="58" as="geometry" />
        </mxCell>

        <!-- AWS KMS box (red) on right -->
        <mxCell id="kmsbox" value="AWS KMS" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#DD344C;strokeWidth=1.5;verticalAlign=top;align=right;fontColor=#232F3E;fontSize=14;spacingRight=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="680" y="110" width="280" height="380" as="geometry" />
        </mxCell>
        <!-- Encrypted data key -->
        <mxCell id="enckey" value="Encrypted data&#10;key" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=13;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.key_management_service;" vertex="1" parent="1">
          <mxGeometry x="820" y="150" width="50" height="50" as="geometry" />
        </mxCell>
        <!-- Root key -->
        <mxCell id="rootkey" value="Root key" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=13;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.key_management_service;" vertex="1" parent="1">
          <mxGeometry x="820" y="280" width="50" height="50" as="geometry" />
        </mxCell>
        <!-- Data key -->
        <mxCell id="datakey" value="Data key" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=13;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.key_management_service;" vertex="1" parent="1">
          <mxGeometry x="820" y="400" width="50" height="50" as="geometry" />
        </mxCell>
        <!-- internal kms arrows enckey<->rootkey<->datakey -->
        <mxCell id="ki1" style="endArrow=block;startArrow=block;html=1;strokeColor=#8C4FFF;strokeWidth=2;" edge="1" parent="1" source="enckey" target="rootkey">
          <mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ki2" style="endArrow=block;startArrow=block;html=1;strokeColor=#8C4FFF;strokeWidth=2;" edge="1" parent="1" source="rootkey" target="datakey">
          <mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Flow arrows with step labels -->
        <!-- 1: KMS(enckey) -> EBS volume: stored with encrypted data -->
        <mxCell id="e1" value="Encrypted data key is stored&#10;with encrypted data." style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=2.5;fontColor=#232F3E;fontSize=12;labelBackgroundColor=#FFFFFF;align=center;verticalAlign=bottom;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="enckey" target="ebs">
          <mxGeometry relative="1" as="geometry"><mxPoint x="0" y="-12" as="offset" /></mxGeometry>
        </mxCell>
        <!-- 2: EBS -> Server vertical: retrieved by hypervisor -->
        <mxCell id="e2" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=2.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="ebs" target="server">
          <mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2lbl" value="Encrypted data key&#10;is retrieved by the&#10;hypervisor hosting&#10;the EC2 instance." style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#232F3E;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="10" y="240" width="150" height="70" as="geometry" />
        </mxCell>
        <!-- 3: Server -> KMS datakey: request made, data key decrypted -->
        <mxCell id="e3" value="Request is made to AWS KMS,&#10;and data key is decrypted and&#10;returned." style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=2.5;fontColor=#232F3E;fontSize=12;labelBackgroundColor=#FFFFFF;align=center;verticalAlign=top;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="server" target="datakey">
          <mxGeometry relative="1" as="geometry"><mxPoint x="0" y="16" as="offset" /></mxGeometry>
        </mxCell>
        <!-- 4: KMS/server -> EBS vertical upward: decrypted data key used -->
        <mxCell id="e4" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=2.5;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="server" target="ebs">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="270" y="378" /><mxPoint x="270" y="170" /></Array>
          </mxGeometry></mxCell>
        <mxCell id="e4lbl" value="Decrypted data key in memory is&#10;used to encrypt or decrypt data." style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#232F3E;whiteSpace=wrap;labelBackgroundColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="300" y="255" width="220" height="40" as="geometry" />
        </mxCell>

        <!-- step badges -->
        <mxCell id="n1" value="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="455" y="150" width="30" height="30" as="geometry" /></mxCell>
        <mxCell id="n2" value="2" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="184" y="262" width="30" height="30" as="geometry" /></mxCell>
        <mxCell id="n3" value="3" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="455" y="380" width="30" height="30" as="geometry" /></mxCell>
        <mxCell id="n4" value="4" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="255" y="262" width="30" height="30" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
