<mxfile host="app.diagrams.net">
  <diagram id="m05-s3-access-points" name="S3 Access Points">
    <mxGraphModel dx="1000" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="540" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Bucket access using Amazon S3 access points" style="text;html=1;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="30" y="16" width="760" height="36" as="geometry" />
        </mxCell>

        <!-- Admin users -->
        <mxCell id="admin" value="Admin" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.users;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="58" height="40" as="geometry" />
        </mxCell>
        <!-- Sales users -->
        <mxCell id="sales" value="Sales" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.users;" vertex="1" parent="1">
          <mxGeometry x="40" y="240" width="58" height="40" as="geometry" />
        </mxCell>
        <!-- Developers users -->
        <mxCell id="devs" value="Developers" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.users;" vertex="1" parent="1">
          <mxGeometry x="40" y="390" width="58" height="40" as="geometry" />
        </mxCell>

        <!-- hostnames -->
        <mxCell id="hn_admin" value="Bucket hostname:&lt;br&gt;DOC-EXAMPLE-BUCKET.s3.us-west-2.amazonaws.com" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="130" y="80" width="360" height="36" as="geometry" />
        </mxCell>
        <mxCell id="hn_sales" value="AP hostname:&lt;br&gt;sales-123456789012.s3-accesspoint.us-west-2.amazonaws.com" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="130" y="230" width="420" height="36" as="geometry" />
        </mxCell>
        <mxCell id="hn_devs" value="AP hostname:&lt;br&gt;dev-123456789012.s3-accesspoint.us-west-2.amazonaws.com" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="130" y="380" width="420" height="36" as="geometry" />
        </mxCell>

        <!-- Access point policies title -->
        <mxCell id="aptitle" value="Access point&lt;br&gt;policies" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="560" y="120" width="120" height="40" as="geometry" />
        </mxCell>

        <!-- AP policy icons (rounded boxes with policy+key glyph look) -->
        <mxCell id="ap_admin" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DD344C;strokeColor=none;fontColor=#FFFFFF;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="170" width="44" height="44" as="geometry" />
        </mxCell>
        <mxCell id="ap_sales" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DD344C;strokeColor=none;fontColor=#FFFFFF;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="240" width="44" height="44" as="geometry" />
        </mxCell>
        <mxCell id="ap_devs" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DD344C;strokeColor=none;fontColor=#FFFFFF;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="390" width="44" height="44" as="geometry" />
        </mxCell>

        <!-- Bucket policy container (green dashed) -->
        <mxCell id="bpbox" value="Bucket policy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1B660F;dashed=1;verticalAlign=top;fontSize=14;fontStyle=1;fontColor=#232F3E;align=center;" vertex="1" parent="1">
          <mxGeometry x="720" y="80" width="240" height="360" as="geometry" />
        </mxCell>
        <!-- bucket policy icon inside -->
        <mxCell id="bp_icon" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7AA116;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="800" y="130" width="48" height="48" as="geometry" />
        </mxCell>
        <!-- S3 bucket inside -->
        <mxCell id="s3bucket" value="S3 bucket&lt;br&gt;DOC-EXAMPLE-BUCKET" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#7AA116;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;" vertex="1" parent="1">
          <mxGeometry x="800" y="220" width="62" height="62" as="geometry" />
        </mxCell>

        <!-- Admin direct double arrow to bucket policy box -->
        <mxCell id="e_admin" style="endArrow=block;startArrow=block;html=1;strokeColor=#7C3AED;strokeWidth=2;" edge="1" parent="1" source="admin" target="bpbox">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="500" y="110" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- Sales double arrow to ap_sales -->
        <mxCell id="e_sales" style="endArrow=block;startArrow=block;html=1;strokeColor=#7C3AED;strokeWidth=2;" edge="1" parent="1" source="sales" target="ap_sales">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Devs double arrow to ap_devs -->
        <mxCell id="e_devs" style="endArrow=block;startArrow=block;html=1;strokeColor=#7C3AED;strokeWidth=2;" edge="1" parent="1" source="devs" target="ap_devs">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ap_sales -> bucket policy -->
        <mxCell id="e_aps_bp" style="endArrow=block;html=1;strokeColor=#7C3AED;strokeWidth=2;" edge="1" parent="1" source="ap_sales" target="bpbox">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ap_devs -> bucket policy -->
        <mxCell id="e_apd_bp" style="endArrow=block;html=1;strokeColor=#7C3AED;strokeWidth=2;" edge="1" parent="1" source="ap_devs" target="bpbox">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
