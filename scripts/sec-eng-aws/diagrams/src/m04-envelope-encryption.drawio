<mxfile host="app.diagrams.net">
  <diagram id="m04-env" name="Envelope encryption">
    <mxGraphModel dx="1000" dy="640" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1040" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Envelope encryption performed by AWS" style="text;html=1;align=left;verticalAlign=middle;fontSize=24;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="30" y="20" width="900" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rule" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#8C4FFF;strokeColor=none;gradientColor=#E7157B;gradientDirection=east;" vertex="1" parent="1">
          <mxGeometry x="30" y="64" width="980" height="4" as="geometry" />
        </mxCell>

        <!-- Big plus on far left -->
        <mxCell id="bigplus" value="+" style="text;html=1;align=center;verticalAlign=middle;fontSize=48;fontColor=#3B1E66;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="240" width="50" height="50" as="geometry" />
        </mxCell>

        <!-- LEFT: AWS KMS box (red dashed) -->
        <mxCell id="kmsbox" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#DD344C;strokeWidth=1.5;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="90" y="110" width="240" height="380" as="geometry" />
        </mxCell>
        <mxCell id="kmslbl" value="AWS KMS" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="240" y="170" width="100" height="24" as="geometry" />
        </mxCell>

        <!-- Root key (red) -->
        <mxCell id="rootkey" value="Root key" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=13;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.key_management_service;" vertex="1" parent="1">
          <mxGeometry x="150" y="140" width="50" height="50" as="geometry" />
        </mxCell>
        <!-- Data key (gray) -->
        <mxCell id="datakey" value="Data key" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#7D8998;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=13;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.key_management_service;" vertex="1" parent="1">
          <mxGeometry x="150" y="260" width="50" height="50" as="geometry" />
        </mxCell>
        <!-- Encrypted data key (gray + lock) -->
        <mxCell id="encdatakey" value="Encrypted data key" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#7D8998;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=13;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.key_management_service;" vertex="1" parent="1">
          <mxGeometry x="150" y="390" width="50" height="50" as="geometry" />
        </mxCell>

        <!-- curved arrow root -> data (encrypts) : approximate with two arrows -->
        <mxCell id="ekmsflow1" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=3;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;curved=1;" edge="1" parent="1" source="rootkey" target="datakey">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="120" y="225" /></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="ekmsflow2" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=3;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="datakey" target="encdatakey">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- big double arrow between KMS and app -->
        <mxCell id="darrow1" value="" style="shape=flexArrow;html=1;startArrow=block;endArrow=block;fillColor=#3B1E66;strokeColor=#3B1E66;width=10;startWidth=24;endWidth=24;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="345" y="290" as="sourcePoint" />
            <mxPoint x="420" y="290" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="darrow1lbl" value="Application&#10;requests data key&#10;for encryption" style="text;html=1;align=center;verticalAlign=top;fontSize=12;fontColor=#232F3E;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="340" y="330" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- MIDDLE: Example application box -->
        <mxCell id="appbox" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#9E9E9E;strokeWidth=1.5;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="110" width="220" height="320" as="geometry" />
        </mxCell>
        <mxCell id="apphdr" value="Example&#10;application" style="text;html=1;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;fontColor=#232F3E;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="450" y="74" width="220" height="36" as="geometry" />
        </mxCell>
        <!-- plaintext data doc -->
        <mxCell id="plain" value="Plaintext&#10;data" style="shape=note;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;strokeWidth=2;size=14;verticalLabelPosition=bottom;verticalAlign=top;align=center;fontColor=#232F3E;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="525" y="150" width="60" height="70" as="geometry" />
        </mxCell>
        <mxCell id="midplus" value="+" style="text;html=1;align=center;verticalAlign=middle;fontSize=32;fontColor=#232F3E;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="535" y="250" width="40" height="40" as="geometry" />
        </mxCell>
        <!-- data key gray -->
        <mxCell id="appdatakey" value="Data key" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#7D8998;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=13;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.key_management_service;" vertex="1" parent="1">
          <mxGeometry x="535" y="300" width="50" height="50" as="geometry" />
        </mxCell>

        <!-- second big double arrow app -> S3 -->
        <mxCell id="darrow2" value="" style="shape=flexArrow;html=1;startArrow=none;endArrow=block;fillColor=#3B1E66;strokeColor=#3B1E66;width=8;endWidth=20;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="685" y="290" as="sourcePoint" />
            <mxPoint x="755" y="290" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="darrow2lbl" value="Encrypted&#10;data and encrypted&#10;data key are&#10;stored" style="text;html=1;align=center;verticalAlign=top;fontSize=12;fontColor=#232F3E;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="675" y="330" width="160" height="80" as="geometry" />
        </mxCell>

        <!-- RIGHT: Amazon S3 box (teal dashed) -->
        <mxCell id="s3box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1B9E77;strokeWidth=1.5;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="790" y="110" width="220" height="360" as="geometry" />
        </mxCell>
        <mxCell id="s3lbl" value="Amazon S3" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="810" y="120" width="120" height="24" as="geometry" />
        </mxCell>
        <!-- encrypted data doc (with lock) -->
        <mxCell id="encdata" value="Encrypted&#10;data" style="shape=note;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;strokeWidth=2;size=14;verticalLabelPosition=bottom;verticalAlign=top;align=center;fontColor=#232F3E;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="870" y="160" width="60" height="70" as="geometry" />
        </mxCell>
        <!-- encrypted data key gray -->
        <mxCell id="s3enckey" value="Encrypted&#10;data key" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#7D8998;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=13;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.key_management_service;" vertex="1" parent="1">
          <mxGeometry x="875" y="320" width="50" height="50" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
