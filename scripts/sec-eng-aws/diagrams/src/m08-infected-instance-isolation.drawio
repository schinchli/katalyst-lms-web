        <mxCell id="t12" value="•  Isolate the instance by placing&#10;    it in a separate security group." style="text;html=1;align=left;verticalAlign=middle;fontSize=15;fontFamily=Amazon Ember;fontColor=#232F3E;" vertex="1" parent="1"><mxGeometry x="740" y="132" width="252" height="60" as="geometry"/></mxCell>
        <mxCell id="t13" value="•  Protect the instance from&#10;    accidental termination with the&#10;    &lt;b&gt;disableApiTermination&lt;/b&gt;&#10;    attribute. (See the following&#10;    API command.)" style="text;html=1;align=left;verticalAlign=middle;fontSize=15;fontFamily=Amazon Ember;fontColor=#232F3E;" vertex="1" parent="1"><mxGeometry x="740" y="210" width="256" height="130" as="geometry"/></mxCell>
        <mxCell id="cli" value="&amp;gt; aws ec2 modify-instance-&#10;attribute --instance-id i-&#10;a123 --groups sg-isolated" style="text;html=1;align=left;verticalAlign=top;fontFamily=Courier New;fontSize=12;fontColor=#3A3A3A;whiteSpace=pre;" vertex="1" parent="1"><mxGeometry x="740" y="360" width="256" height="80" as="geometry"/></mxCell>
        <mxCell id="cli2" value="&amp;gt; aws ec2 modify-instance-&#10;attribute --instance-id i-&#10;a123 --attribute&#10;disableApiTermination --&#10;value true" style="text;html=1;align=left;verticalAlign=top;fontFamily=Courier New;fontSize=12;fontColor=#3A3A3A;whiteSpace=pre;" vertex="1" parent="1"><mxGeometry x="740" y="442" width="256" height="110" as="geometry"/></mxCell>
