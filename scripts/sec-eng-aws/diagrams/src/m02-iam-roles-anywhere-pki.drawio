<mxfile host="app.diagrams.net">
  <diagram id="m02-roles-anywhere" name="IAM Roles Anywhere PKI">
    <mxGraphModel dx="1000" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1080" pageHeight="540" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- rolesanywhere domain label -->
        <mxCell id="domain" value="rolesanywhere.amazonaws.com" style="text;html=1;align=left;verticalAlign=middle;fontSize=18;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="380" height="26" as="geometry" />
        </mxCell>

        <!-- Allow policy scroll -->
        <mxCell id="scroll" value="" style="shape=document;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9E9E9E;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="20" y="70" width="300" height="120" as="geometry" />
        </mxCell>
        <mxCell id="allowtxt" value="Allow&lt;br&gt;&lt;br&gt;&#160;&#160;sts:AssumeRole&lt;br&gt;&#160;&#160;sts:SetSourceIdentity&lt;br&gt;&#160;&#160;sts:TagSession" style="text;html=1;align=left;verticalAlign=top;fontSize=15;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="36" y="80" width="280" height="100" as="geometry" />
        </mxCell>

        <!-- X.509 certificate icon -->
        <mxCell id="certicon" value="&#127894;" style="text;html=1;align=center;verticalAlign=middle;fontSize=54;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="438" y="20" width="90" height="70" as="geometry" />
        </mxCell>
        <mxCell id="cert" value="X.509 certificate" style="text;html=1;align=center;verticalAlign=top;fontSize=18;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="390" y="92" width="220" height="30" as="geometry" />
        </mxCell>

        <!-- Trust anchor label -->
        <mxCell id="trust" value="Trust anchor" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="700" y="20" width="220" height="26" as="geometry" />
        </mxCell>

        <!-- PKI infrastructure central box -->
        <mxCell id="pki" value="PKI infrastructure" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4B0082;strokeColor=none;fontColor=#FFFFFF;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="370" y="195" width="280" height="50" as="geometry" />
        </mxCell>
        <!-- decorative side brackets on PKI -->
        <mxCell id="pkibrL" value="" style="shape=curlyBracket;html=1;rounded=1;strokeColor=#4B0082;strokeWidth=2;direction=north;" vertex="1" parent="1">
          <mxGeometry x="372" y="160" width="120" height="20" as="geometry" />
        </mxCell>
        <mxCell id="pkibrR" value="" style="shape=curlyBracket;html=1;rounded=1;strokeColor=#4B0082;strokeWidth=2;direction=north;" vertex="1" parent="1">
          <mxGeometry x="528" y="160" width="120" height="20" as="geometry" />
        </mxCell>
        <mxCell id="pkibrB" value="" style="shape=curlyBracket;html=1;rounded=1;strokeColor=#4B0082;strokeWidth=2;direction=south;" vertex="1" parent="1">
          <mxGeometry x="450" y="258" width="120" height="20" as="geometry" />
        </mxCell>

        <!-- IAM role (hat) -->
        <mxCell id="role" value="IAM role" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=18;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.role;" vertex="1" parent="1">
          <mxGeometry x="40" y="290" width="64" height="64" as="geometry" />
        </mxCell>

        <!-- AWS Private CA -->
        <mxCell id="ca" value="AWS Private Certificate&lt;br&gt;Authority" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=18;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.certificate_manager;" vertex="1" parent="1">
          <mxGeometry x="478" y="320" width="64" height="64" as="geometry" />
        </mxCell>

        <!-- Your workload (database stack) -->
        <mxCell id="workload" value="Your workload" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=18;aspect=fixed;shape=mxgraph.aws4.traditional_server;" vertex="1" parent="1">
          <mxGeometry x="930" y="240" width="80" height="80" as="geometry" />
        </mxCell>

        <!-- dotted connectors -->
        <mxCell id="d_scroll_pki" value="" style="endArrow=none;html=1;strokeColor=#4B0082;strokeWidth=2;dashed=1;dashPattern=1 4;exitX=1;exitY=0.4;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;" edge="1" parent="1" source="scroll" target="pki">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d_role_pki" value="" style="endArrow=none;html=1;strokeColor=#4B0082;strokeWidth=2;dashed=1;dashPattern=1 4;exitX=0.7;exitY=0;exitDx=0;exitDy=0;entryX=0.1;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="role" target="pki">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d_cert_pki" value="" style="endArrow=none;html=1;strokeColor=#4B0082;strokeWidth=2;dashed=1;dashPattern=1 4;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.4;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="certicon" target="pki">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d_ca_pki" value="" style="endArrow=none;html=1;strokeColor=#4B0082;strokeWidth=2;dashed=1;dashPattern=1 4;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="ca" target="pki">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d_trust_pki" value="" style="endArrow=none;html=1;strokeColor=#4B0082;strokeWidth=2;dashed=1;dashPattern=1 4;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.3;entryDx=0;entryDy=0;" edge="1" parent="1" source="trust" target="pki">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d_work_pki" value="" style="endArrow=none;html=1;strokeColor=#4B0082;strokeWidth=2;dashed=1;dashPattern=1 4;exitX=0.2;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=0.1;entryDx=0;entryDy=0;" edge="1" parent="1" source="workload" target="trust">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
