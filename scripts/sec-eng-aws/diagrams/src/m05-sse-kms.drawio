<mxfile host="app.diagrams.net">
  <diagram id="m05-sse-kms" name="SSE-KMS">
    <mxGraphModel dx="1000" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Server-side encryption with AWS KMS" style="text;html=1;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="30" y="16" width="700" height="36" as="geometry" />
        </mxCell>

        <!-- Top dashed boundary box -->
        <mxCell id="topbox" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#DD344C;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="130" y="80" width="720" height="150" as="geometry" />
        </mxCell>

        <!-- Step 1 text -->
        <mxCell id="t1" value="Amazon S3 obtains the&lt;br&gt;data key from KMS." style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="178" y="92" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="b1" value="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="150" y="92" width="24" height="24" as="geometry" />
        </mxCell>

        <!-- Step 2 text -->
        <mxCell id="t2" value="The data key is encrypted with&lt;br&gt;an KMS key." style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="448" y="92" width="220" height="40" as="geometry" />
        </mxCell>
        <mxCell id="b2" value="2" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="92" width="24" height="24" as="geometry" />
        </mxCell>

        <!-- AWS KMS -->
        <mxCell id="kms" value="AWS KMS" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.key_management_service;" vertex="1" parent="1">
          <mxGeometry x="770" y="100" width="52" height="52" as="geometry" />
        </mxCell>

        <!-- Data key label (left, under step1) -->
        <mxCell id="dklab1" value="Data key" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="178" y="150" width="80" height="20" as="geometry" />
        </mxCell>
        <!-- KMS key label -->
        <mxCell id="kmsklab" value="KMS key" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="440" y="150" width="80" height="20" as="geometry" />
        </mxCell>

        <!-- Bottom dashed boundary box -->
        <mxCell id="botbox" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#DD344C;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="290" width="610" height="170" as="geometry" />
        </mxCell>

        <!-- Data Plaintext doc -->
        <mxCell id="data" value="Data&lt;br&gt;(Plaintext)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.documents;" vertex="1" parent="1">
          <mxGeometry x="40" y="330" width="48" height="58" as="geometry" />
        </mxCell>

        <!-- HTTPS pill -->
        <mxCell id="https" value="HTTPS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=none;fontColor=#FFFFFF;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="346" width="80" height="28" as="geometry" />
        </mxCell>

        <!-- Amazon S3 -->
        <mxCell id="s3" value="Amazon S3" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#7AA116;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;" vertex="1" parent="1">
          <mxGeometry x="250" y="328" width="52" height="52" as="geometry" />
        </mxCell>

        <!-- Data key doc (middle) -->
        <mxCell id="dkdoc" value="Data key" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.documents;" vertex="1" parent="1">
          <mxGeometry x="430" y="330" width="48" height="58" as="geometry" />
        </mxCell>

        <!-- Encrypted bucket (green) -->
        <mxCell id="bucket" value="Data key" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#7AA116;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;" vertex="1" parent="1">
          <mxGeometry x="660" y="320" width="62" height="62" as="geometry" />
        </mxCell>

        <!-- Step 3 text -->
        <mxCell id="b3" value="3" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B1E66;strokeColor=none;fontColor=#FFFFFF;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="424" width="24" height="24" as="geometry" />
        </mxCell>
        <mxCell id="t3" value="Encrypted data and an encrypted data key are&lt;br&gt;stored in an S3 bucket." style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="462" y="424" width="320" height="40" as="geometry" />
        </mxCell>

        <!-- Arrows -->
        <!-- data -> HTTPS -> S3 -->
        <mxCell id="e_data_s3" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=2;" edge="1" parent="1" source="data" target="s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- S3 up to top box (step1, get data key) -->
        <mxCell id="e_s3_kms" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=2;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="s3" target="dklab1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- data key in top down to middle dkdoc -->
        <mxCell id="e_dk_down" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=2;" edge="1" parent="1" source="kmsklab" target="dkdoc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- dkdoc -> bucket -->
        <mxCell id="e_dk_bucket" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=2;" edge="1" parent="1" source="dkdoc" target="bucket">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- KMS key label up to AWS KMS -->
        <mxCell id="e_kmsk_kms" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=2;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="kmsklab" target="kms">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
