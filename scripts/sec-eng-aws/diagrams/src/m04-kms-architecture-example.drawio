<mxfile host="app.diagrams.net">
  <diagram id="m04-archex" name="CloudHSM architecture example">
    <mxGraphModel dx="1000" dy="640" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1040" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Architecture example" style="text;html=1;align=left;verticalAlign=middle;fontSize=24;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="30" y="20" width="600" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rule" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#8C4FFF;strokeColor=none;gradientColor=#E7157B;gradientDirection=east;" vertex="1" parent="1">
          <mxGeometry x="30" y="64" width="980" height="4" as="geometry" />
        </mxCell>

        <!-- AWS Cloud boundary -->
        <mxCell id="cloud" value="AWS Cloud" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#232F3E;strokeWidth=1.5;verticalAlign=top;align=left;fontColor=#232F3E;fontSize=14;spacingLeft=30;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="560" height="430" as="geometry" />
        </mxCell>
        <mxCell id="cloudicon" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;html=1;aspect=fixed;shape=mxgraph.aws4.aws_cloud_alt;" vertex="1" parent="1">
          <mxGeometry x="52" y="108" width="22" height="22" as="geometry" />
        </mxCell>

        <!-- Amazon VPC boundary (green) -->
        <mxCell id="vpc" value="Amazon VPC" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#7AA116;strokeWidth=1.5;verticalAlign=top;align=left;fontColor=#7AA116;fontSize=13;spacingLeft=28;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="70" y="150" width="500" height="350" as="geometry" />
        </mxCell>
        <mxCell id="vpcicon" value="" style="sketch=0;outlineConnect=0;fontColor=#7AA116;gradientColor=none;fillColor=#7AA116;strokeColor=none;html=1;aspect=fixed;shape=mxgraph.aws4.virtual_private_cloud;" vertex="1" parent="1">
          <mxGeometry x="80" y="156" width="20" height="20" as="geometry" />
        </mxCell>

        <!-- Cluster label + dashed boundary on right portion -->
        <mxCell id="clusterlbl" value="Cluster" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="380" y="170" width="140" height="20" as="geometry" />
        </mxCell>
        <mxCell id="cluster" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#00A1C9;strokeWidth=1.5;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="195" width="190" height="280" as="geometry" />
        </mxCell>

        <!-- Subnet 1 (top, dashed blue) -->
        <mxCell id="sub1" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EAF6FB;strokeColor=#00A1C9;strokeWidth=1.5;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="95" y="200" width="450" height="120" as="geometry" />
        </mxCell>
        <!-- Subnet 2 (bottom, dashed blue) -->
        <mxCell id="sub2" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EAF6FB;strokeColor=#00A1C9;strokeWidth=1.5;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="95" y="340" width="450" height="120" as="geometry" />
        </mxCell>

        <!-- App with CloudHSM client (top) -->
        <mxCell id="app1" value="Application with&#10;CloudHSM client" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ec2;" vertex="1" parent="1">
          <mxGeometry x="140" y="225" width="52" height="52" as="geometry" />
        </mxCell>
        <!-- CloudHSM instance 1 (top, in cluster) -->
        <mxCell id="hsm1" value="CloudHSM&#10;instance 1" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudhsm;" vertex="1" parent="1">
          <mxGeometry x="410" y="225" width="52" height="52" as="geometry" />
        </mxCell>
        <!-- App with CloudHSM client (bottom) -->
        <mxCell id="app2" value="Application with&#10;CloudHSM client" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ec2;" vertex="1" parent="1">
          <mxGeometry x="140" y="365" width="52" height="52" as="geometry" />
        </mxCell>
        <!-- CloudHSM instance 2 (bottom, in cluster) -->
        <mxCell id="hsm2" value="CloudHSM&#10;instance 2" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudhsm;" vertex="1" parent="1">
          <mxGeometry x="410" y="365" width="52" height="52" as="geometry" />
        </mxCell>

        <!-- connect apps to hsm -->
        <mxCell id="ec1" style="endArrow=block;startArrow=block;html=1;strokeColor=#232F3E;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="app1" target="hsm1">
          <mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ec2e" style="endArrow=block;startArrow=block;html=1;strokeColor=#232F3E;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="app2" target="hsm2">
          <mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Right bullet list -->
        <mxCell id="bullets" value="&#8226; Create up to 28 HSMs per&#10;   cluster.&#10;&#10;&#8226; Add or remove HSMs to&#10;   the cluster to meet&#10;   demand.&#10;&#10;&#8226; Pay only for the&#10;   provisioned instances in&#10;   the cluster." style="text;html=1;align=left;verticalAlign=top;fontSize=16;fontColor=#232F3E;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="640" y="170" width="370" height="280" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
