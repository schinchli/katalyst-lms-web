<mxfile host="app.diagrams.net">
  <diagram id="m02-iam-eval-flow" name="IAM security evaluation flow">
    <mxGraphModel dx="1000" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1180" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Big vertical arrow: Logical flow of security evaluation -->
        <mxCell id="bigarrow" value="" style="shape=singleArrow;direction=south;whiteSpace=wrap;html=1;fillColor=#8C7AE6;strokeColor=none;arrowWidth=0.55;arrowSize=0.25;" vertex="1" parent="1">
          <mxGeometry x="60" y="30" width="60" height="580" as="geometry" />
        </mxCell>
        <mxCell id="bigarrowlbl" value="Logical flow of security evaluation" style="text;html=1;align=center;verticalAlign=middle;rotation=-90;fontSize=18;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="-118" y="290" width="380" height="30" as="geometry" />
        </mxCell>

        <!-- AWS Cloud outer box -->
        <mxCell id="awscloud" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#232F3E;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="170" y="20" width="990" height="600" as="geometry" />
        </mxCell>
        <mxCell id="awsicon" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;html=1;aspect=fixed;shape=mxgraph.aws4.aws_cloud_alt;" vertex="1" parent="1">
          <mxGeometry x="184" y="34" width="34" height="34" as="geometry" />
        </mxCell>
        <mxCell id="awscloudlbl" value="AWS Cloud" style="text;html=1;align=left;verticalAlign=middle;fontSize=18;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="228" y="34" width="160" height="34" as="geometry" />
        </mxCell>

        <!-- Dashed red IAM boundary -->
        <mxCell id="iamboundary" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#D6336C;dashed=1;dashPattern=8 6;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="330" y="50" width="810" height="490" as="geometry" />
        </mxCell>

        <!-- AWS IAM icon -->
        <mxCell id="iam" value="&lt;b&gt;AWS&lt;br&gt;IAM&lt;/b&gt;" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=14;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.identity_and_access_management;" vertex="1" parent="1">
          <mxGeometry x="346" y="92" width="58" height="58" as="geometry" />
        </mxCell>

        <!-- User -->
        <mxCell id="user" value="User" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;verticalLabelPosition=top;verticalAlign=bottom;align=center;html=1;fontSize=15;aspect=fixed;shape=mxgraph.aws4.user;" vertex="1" parent="1">
          <mxGeometry x="478" y="100" width="56" height="56" as="geometry" />
        </mxCell>

        <!-- Group -->
        <mxCell id="group" value="Group" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;verticalLabelPosition=top;verticalAlign=bottom;align=center;html=1;fontSize=15;aspect=fixed;shape=mxgraph.aws4.users;" vertex="1" parent="1">
          <mxGeometry x="690" y="100" width="64" height="56" as="geometry" />
        </mxCell>

        <!-- Role (hat) -->
        <mxCell id="role" value="Role" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=none;verticalLabelPosition=top;verticalAlign=bottom;align=center;html=1;fontSize=15;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.role;" vertex="1" parent="1">
          <mxGeometry x="912" y="100" width="58" height="58" as="geometry" />
        </mxCell>

        <!-- Policy (checklist) on right -->
        <mxCell id="policyicon" value="&#10003;&#10003;&#10007;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DD344C;strokeWidth=2;fontSize=18;fontColor=#DD344C;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1036" y="332" width="34" height="46" as="geometry" />
        </mxCell>
        <mxCell id="policylbl" value="Policy" style="text;html=1;align=center;verticalAlign=middle;fontSize=15;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="1020" y="302" width="70" height="24" as="geometry" />
        </mxCell>
        <mxCell id="policytypes" value="AWS&lt;br&gt;managed&lt;br&gt;- - - - - -&lt;br&gt;Customer-&lt;br&gt;managed&lt;br&gt;- - - - - -&lt;br&gt;Inline" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="1080" y="288" width="80" height="140" as="geometry" />
        </mxCell>

        <!-- Resource-based permissions box -->
        <mxCell id="resbased" value="Resource-based&lt;br&gt;permissions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7B2D5E;strokeWidth=3;fontSize=15;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="206" y="340" width="200" height="80" as="geometry" />
        </mxCell>

        <!-- plus sign -->
        <mxCell id="plus" value="+" style="text;html=1;align=center;verticalAlign=middle;fontSize=40;fontStyle=1;fontColor=#6B8E23;" vertex="1" parent="1">
          <mxGeometry x="408" y="358" width="48" height="48" as="geometry" />
        </mxCell>

        <!-- Identity-based permissions box -->
        <mxCell id="idbased" value="Identity-based permissions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7B2D5E;strokeWidth=3;fontSize=20;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="466" y="335" width="510" height="90" as="geometry" />
        </mxCell>

        <!-- Additional security controls box -->
        <mxCell id="addctrl" value="Additional security controls within a service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#8C7AE6;strokeWidth=3;fontSize=20;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="206" y="520" width="770" height="80" as="geometry" />
        </mxCell>

        <!-- Arrows: user/group/role down to identity-based -->
        <mxCell id="a_user" value="" style="endArrow=block;html=1;strokeColor=#8C7AE6;strokeWidth=6;endFill=1;" edge="1" parent="1" source="user" target="idbased">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="506" y="250" /><mxPoint x="600" y="250" /></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="a_group" value="" style="endArrow=block;html=1;strokeColor=#8C7AE6;strokeWidth=6;endFill=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="group" target="idbased">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_role" value="" style="endArrow=block;html=1;strokeColor=#8C7AE6;strokeWidth=6;endFill=1;" edge="1" parent="1" source="role" target="idbased">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="941" y="250" /><mxPoint x="860" y="250" /></Array>
          </mxGeometry>
        </mxCell>

        <!-- Policy -> identity-based (left arrow) -->
        <mxCell id="a_policy" value="" style="endArrow=block;html=1;strokeColor=#8C7AE6;strokeWidth=6;endFill=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="policyicon" target="idbased">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Resource-based -> additional controls (down) -->
        <mxCell id="a_resdown" value="" style="endArrow=block;html=1;strokeColor=#8C7AE6;strokeWidth=6;endFill=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.3;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="resbased" target="addctrl">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Identity-based -> additional controls (down) -->
        <mxCell id="a_iddown" value="" style="endArrow=block;html=1;strokeColor=#8C7AE6;strokeWidth=6;endFill=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.6;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="idbased" target="addctrl">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
