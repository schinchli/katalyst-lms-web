<mxfile host="app.diagrams.net">
  <diagram id="m03-scp-deny" name="SCP inheritance deny example">
    <mxGraphModel dx="1000" dy="520" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1240" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Default SCP title -->
        <mxCell id="scptitle" value="&lt;b&gt;Default SCP:&lt;/b&gt; FullAWSAccess" style="text;html=1;align=left;verticalAlign=middle;fontColor=#232F3E;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="30" y="20" width="420" height="30" as="geometry" />
        </mxCell>
        <!-- Default SCP JSON box -->
        <mxCell id="scpjson" value="{&#10;&#160;&#160;&quot;Effect&quot;: &quot;Allow&quot;,&#10;&#160;&#160;&quot;Action&quot;: &quot;*&quot;,&#10;&#160;&#160;&quot;Resource&quot;: &quot;*&quot;&#10;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EFEFEF;strokeColor=#9E9E9E;align=left;verticalAlign=top;fontFamily=Courier New;fontSize=18;fontColor=#1F3864;spacingLeft=10;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="60" width="370" height="170" as="geometry" />
        </mxCell>
        <!-- checklist icon inside SCP box -->
        <mxCell id="scpcheck" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#DD344C;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="300" y="105" width="60" height="70" as="geometry" />
        </mxCell>

        <!-- OU 1 icon -->
        <mxCell id="ou1" value="OU 1" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.organizations_organizational_unit;sketch=0;outlineConnect=0;fillColor=#CD2264;strokeColor=none;verticalLabelPosition=right;verticalAlign=middle;align=left;labelPosition=left;html=1;fontSize=18;fontColor=#232F3E;fontStyle=1;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="500" y="280" width="64" height="64" as="geometry" />
        </mxCell>
        <!-- OU 2 icon -->
        <mxCell id="ou2" value="OU 2" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.organizations_organizational_unit;sketch=0;outlineConnect=0;fillColor=#CD2264;strokeColor=none;verticalLabelPosition=right;verticalAlign=middle;align=left;labelPosition=right;html=1;fontSize=18;fontColor=#232F3E;fontStyle=1;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="860" y="280" width="64" height="64" as="geometry" />
        </mxCell>

        <!-- OU 1 result box (light blue) -->
        <mxCell id="box1" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D9F2FB;strokeColor=#90CAF9;" vertex="1" parent="1">
          <mxGeometry x="20" y="380" width="580" height="290" as="geometry" />
        </mxCell>
        <mxCell id="box1txt" value="&lt;font color=&quot;#CD2264&quot;&gt;&lt;b&gt;Inherited:&lt;/b&gt;&lt;/font&gt; FullAWSAccess&lt;br&gt;&lt;font color=&quot;#3B1E66&quot;&gt;&lt;b&gt;Attached:&lt;/b&gt;&lt;/font&gt; None" style="text;html=1;align=left;verticalAlign=top;fontColor=#232F3E;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="40" y="400" width="540" height="60" as="geometry" />
        </mxCell>
        <mxCell id="box1state" value="&lt;i&gt;Default state&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=bottom;fontColor=#666666;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="40" y="610" width="200" height="40" as="geometry" />
        </mxCell>

        <!-- OU 2 result box (grey) -->
        <mxCell id="box2" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EFEFEF;strokeColor=#BDBDBD;" vertex="1" parent="1">
          <mxGeometry x="640" y="380" width="580" height="290" as="geometry" />
        </mxCell>
        <mxCell id="box2txt" value="&lt;font color=&quot;#CD2264&quot;&gt;&lt;b&gt;Inherited:&lt;/b&gt;&lt;/font&gt; FullAWSAccess&lt;br&gt;&lt;font color=&quot;#3B1E66&quot;&gt;&lt;b&gt;Attached:&lt;/b&gt;&lt;/font&gt; Deny_DeleteLogs" style="text;html=1;align=left;verticalAlign=top;fontColor=#232F3E;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="660" y="400" width="540" height="60" as="geometry" />
        </mxCell>
        <mxCell id="box2json" value="{&#10;&#160;&quot;Effect&quot;: &quot;Deny&quot;,&#10;&#160;&quot;Action&quot;: [&#10;&#160;&#160;&#160;&#160;&quot;ec2:DeleteFlowLogs&quot;,&#10;&#160;&#160;&#160;&#160;&quot;logs:DeleteLogGroup&quot;,&#10;&#160;&#160;&#160;&#160;&quot;logs:DeleteLogStream&quot;,]&#10;&#160;&quot;Resource&quot;: &quot;*&quot;&#10;}" style="text;html=1;align=left;verticalAlign=top;fontFamily=Courier New;fontSize=17;fontColor=#1F3864;" vertex="1" parent="1">
          <mxGeometry x="660" y="470" width="540" height="190" as="geometry" />
        </mxCell>

        <!-- star on OU 2 box -->
        <mxCell id="star" value="" style="shape=mxgraph.basic.star;fillColor=#FFD400;strokeColor=#E6A700;html=1;" vertex="1" parent="1">
          <mxGeometry x="1150" y="350" width="80" height="80" as="geometry" />
        </mxCell>

        <!-- arrow from SCP box rightward, then T-split down to OU 1 and OU 2 -->
        <mxCell id="e_right" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=4;exitX=1;exitY=0.4;entryX=0;entryY=0.5;rounded=0;" edge="1" parent="1" source="scpjson">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="690" y="128" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- down split to OU1 -->
        <mxCell id="e_ou1" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=4;rounded=0;entryX=0.5;entryY=0;" edge="1" parent="1" target="ou1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="690" y="180" as="sourcePoint" />
            <Array as="points">
              <mxPoint x="532" y="180" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- down split to OU2 -->
        <mxCell id="e_ou2" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=4;rounded=0;entryX=0.5;entryY=0;" edge="1" parent="1" target="ou2">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="690" y="180" as="sourcePoint" />
            <Array as="points">
              <mxPoint x="892" y="180" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- horizontal connector at y=180 between the two split points -->
        <mxCell id="e_hbar" style="endArrow=none;html=1;strokeColor=#3B1E66;strokeWidth=4;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="532" y="180" as="sourcePoint" />
            <mxPoint x="892" y="180" as="targetPoint" />
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
