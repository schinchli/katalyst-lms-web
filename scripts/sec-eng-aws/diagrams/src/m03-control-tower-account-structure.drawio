<mxfile host="app.diagrams.net">
  <diagram id="m03-ct-acct-struct" name="Control Tower account structure">
    <mxGraphModel dx="1000" dy="520" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1320" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== LEFT panel: basic org ===== -->
        <mxCell id="lpanel" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#DD344C;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="500" height="600" as="geometry" />
        </mxCell>

        <!-- left management account icon -->
