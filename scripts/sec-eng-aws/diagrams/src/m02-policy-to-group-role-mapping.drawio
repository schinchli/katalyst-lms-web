<mxfile host="app.diagrams.net">
  <diagram id="m02-policy-mapping" name="Policy to group role mapping">
    <mxGraphModel dx="900" dy="700" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="760" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- AWS Cloud outer box -->
        <mxCell id="awscloud" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#232F3E;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="10" y="10" width="880" height="740" as="geometry" />
        </mxCell>
        <mxCell id="awsicon" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;html=1;aspect=fixed;shape=mxgraph.aws4.aws_cloud_alt;" vertex="1" parent="1">
          <mxGeometry x="22" y="22" width="34" height="34" as="geometry" />
        </mxCell>
        <mxCell id="awscloudlbl" value="AWS Cloud" style="text;html=1;align=left;verticalAlign=middle;fontSize=20;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="66" y="22" width="180" height="34" as="geometry" />
