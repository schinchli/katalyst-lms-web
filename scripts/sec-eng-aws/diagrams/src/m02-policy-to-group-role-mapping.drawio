        <mxCell id="pol3" value="&#10003;&#10003;&#10007;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DD344C;strokeWidth=2.5;fontSize=22;fontColor=#DD344C;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
