<mxfile host="app.diagrams.net">
  <diagram id="m07-opensearch" name="OpenSearch Service workflow">
    <mxGraphModel dx="1000" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="540" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="OpenSearch Service workflow" style="text;html=1;align=left;verticalAlign=middle;fontColor=#16191F;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="600" height="40" as="geometry" />
        </mxCell>

        <!-- Collection: cluster of documents -->
        <mxCell id="docA" value="" style="shape=note;whiteSpace=wrap;html=1;fillColor=#E6E0F8;strokeColor=#8C4FFF;size=14;" vertex="1" parent="1">
          <mxGeometry x="60" y="180" width="44" height="54" as="geometry" />
        </mxCell>
        <mxCell id="docB" value="" style="shape=note;whiteSpace=wrap;html=1;fillColor=#E6E0F8;strokeColor=#8C4FFF;size=14;" vertex="1" parent="1">
          <mxGeometry x="96" y="160" width="44" height="54" as="geometry" />
        </mxCell>
        <mxCell id="docC" value="" style="shape=note;whiteSpace=wrap;html=1;fillColor=#E6E0F8;strokeColor=#8C4FFF;size=14;" vertex="1" parent="1">
          <mxGeometry x="78" y="216" width="44" height="54" as="geometry" />
        </mxCell>
        <mxCell id="collLabel" value="Collection" style="text;html=1;align=center;fontColor=#16191F;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="40" y="278" width="120" height="26" as="geometry" />
        </mxCell>

        <!-- Aggregation parens -->
        <mxCell id="parenL1" value="(" style="text;html=1;align=center;fontColor=#8C4FFF;fontSize=64;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="180" y="150" width="40" height="120" as="geometry" />
        </mxCell>
        <mxCell id="funnel" value="" style="shape=note;whiteSpace=wrap;html=1;fillColor=#C9B8F2;strokeColor=#6B2FB5;size=16;" vertex="1" parent="1">
          <mxGeometry x="232" y="170" width="60" height="74" as="geometry" />
        </mxCell>
        <mxCell id="funnelIcon" value="&#9660;" style="text;html=1;align=center;fontColor=#4B1F8C;fontSize=22;" vertex="1" parent="1">
          <mxGeometry x="232" y="190" width="60" height="30" as="geometry" />
        </mxCell>
        <mxCell id="parenR1" value=")" style="text;html=1;align=center;fontColor=#8C4FFF;fontSize=64;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="150" width="40" height="120" as="geometry" />
        </mxCell>
        <mxCell id="aggLabel" value="Aggregation" style="text;html=1;align=center;fontColor=#16191F;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="150" y="320" width="160" height="26" as="geometry" />
        </mxCell>
        <mxCell id="transLabel" value="Transformation" style="text;html=1;align=center;fontColor=#16191F;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="300" y="362" width="160" height="26" as="geometry" />
        </mxCell>

        <!-- OpenSearch icon (elasticsearch_service sprite) -->
        <mxCell id="opensearch" value="" style="sketch=0;fontColor=#232F3E;fillColor=#8C4FFF;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elasticsearch_service;" vertex="1" parent="1">
          <mxGeometry x="430" y="178" width="74" height="74" as="geometry" />
        </mxCell>

        <!-- Analysis circle -->
        <mxCell id="analysis" value="Analysis" style="ellipse;whiteSpace=wrap;html=1;fillColor=#9B1B6B;strokeColor=none;fontColor=#FFFFFF;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="70" width="110" height="110" as="geometry" />
        </mxCell>
        <mxCell id="analysisBullets" value="&#8226; Search&lt;br&gt;&#8226; Index&lt;br&gt;&#8226; Monitor" style="text;html=1;align=left;verticalAlign=middle;fontColor=#16191F;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="730" y="90" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- Dashboards circle -->
        <mxCell id="dashboards" value="Dashboards" style="ellipse;whiteSpace=wrap;html=1;fillColor=#9B1B6B;strokeColor=none;fontColor=#FFFFFF;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="270" width="110" height="110" as="geometry" />
        </mxCell>
        <mxCell id="dashBullets" value="&#8226; Visualization&lt;br&gt;&#8226; Data correlation" style="text;html=1;align=left;verticalAlign=middle;fontColor=#16191F;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="730" y="300" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- Arrows: collection -> aggregation -->
        <mxCell id="ar1" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=2.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;" edge="1" parent="1" source="collLabel" target="aggLabel">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- aggregation -> transformation -->
        <mxCell id="ar2" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=2.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;" edge="1" parent="1" source="aggLabel" target="transLabel">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- transformation -> opensearch (up) -->
        <mxCell id="ar3" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=2.5;exitX=0.7;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;" edge="1" parent="1" source="transLabel" target="opensearch">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- opensearch -> analysis -->
        <mxCell id="ar4" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=2.5;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.8;" edge="1" parent="1" source="opensearch" target="analysis">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- opensearch -> dashboards -->
        <mxCell id="ar5" style="endArrow=block;html=1;strokeColor=#3B1E66;strokeWidth=2.5;exitX=1;exitY=0.7;exitDx=0;exitDy=0;entryX=0;entryY=0.2;" edge="1" parent="1" source="opensearch" target="dashboards">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
