# ─── Vercel only needs: apps/web/src + apps/web config files + vercel.json ────
# Everything below is excluded from upload.

# Other apps (not deployed to Vercel)
apps/admin/

# Monorepo packages (not imported by apps/web)
packages/

# Backend — AWS Lambda (deployed via CDK/SAM separately)
backend/

# Mobile — Expo / React Native
mobile/

# Infrastructure — AWS CDK
infrastructure/

# iOS native code
ios/

# Supabase migrations (run via Supabase CLI)
supabase/

# Legacy / unused folders
frontend/
docs/

# ─── apps/web internal exclusions ─────────────────────────────────────────────
apps/web/e2e/
apps/web/scripts/
apps/web/jest.config.ts
apps/web/playwright.config.ts
apps/web/tsconfig.tsbuildinfo

# ─── Test files (anywhere) ────────────────────────────────────────────────────
**/__tests__/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
coverage/

# ─── Build artifacts (Vercel rebuilds these) ──────────────────────────────────
**/node_modules/
apps/web/.next/
**/*.tsbuildinfo

# ─── Data backups ─────────────────────────────────────────────────────────────
apps/web/src/data/*_backup_*

# ─── Root-level docs & planning (not part of build) ──────────────────────────
*.md
app.json
turbo.json
CLAUDE.md
CLAUDE_COMMANDMENTS.md

# ─── Secrets & local env ──────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── IDE / OS / CI ────────────────────────────────────────────────────────────
.DS_Store
.kiro/
.cursor/
.vscode/
.github/
