# ─── Vercel only needs: apps/web/src + apps/web config files + vercel.json ────
# Everything below is excluded from upload.

# Other apps (not deployed to Vercel)
apps/admin/

# Local agent configs (not part of build)
/agents/

# Monorepo packages — needed by workspace resolution
# apps/web imports @lms/shared-types and @lms/theme; keep these folders
# packages/

# Backend — AWS Lambda (deployed via CDK/SAM separately)
backend/

# Mobile — Expo / React Native
mobile/

# Infrastructure — AWS CDK
infrastructure/

# iOS native code
ios/

# Supabase migrations (run via Supabase CLI)
supabase/

# Docs (not part of build)
docs/

# ─── apps/web internal exclusions ─────────────────────────────────────────────
apps/web/e2e/
apps/web/scripts/
apps/web/jest.config.ts
apps/web/playwright.config.ts
apps/web/tsconfig.tsbuildinfo

# ─── Test files (anywhere) ────────────────────────────────────────────────────
**/__tests__/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
coverage/

# ─── Build artifacts (Vercel rebuilds these) ──────────────────────────────────
node_modules
**/node_modules
.next
**/.next
apps/web/test-results
apps/web/e2e-report
apps/web/e2e-screenshots
**/*.tsbuildinfo
.expo
.turbo
.code-review-graph
.understand-anything

# ─── Data backups ─────────────────────────────────────────────────────────────
apps/web/src/data/*_backup_*

# ─── Root-level docs & planning (not part of build) ──────────────────────────
*.md
app.json
turbo.json
CLAUDE.md
CLAUDE_COMMANDMENTS.md

# ─── Secrets & local env ──────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── IDE / OS / CI ────────────────────────────────────────────────────────────
.DS_Store
.kiro/
.cursor/
.vscode/
.github/
